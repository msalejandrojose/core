// Prisma schema — https://pris.ly/d/prisma-schema
//
// Notas:
// - Generador `prisma-client` (nuevo en Prisma 7, sin Rust engine). El cliente
//   se emite a `src/generated/prisma/` para que `nest build` lo compile junto
//   con el resto del código y sobreviva al `pnpm deploy` dentro de Docker.
// - El `url` ya NO va aquí. Vive en `prisma.config.ts` (CLI) y en el
//   constructor de `PrismaClient` vía driver adapter (runtime).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Discriminador de tipo de usuario. Permite un único modelo `User` con email
/// globalmente único, evitando tablas separadas por tipo.
enum UserType {
  BACKOFFICE
  APP
}

/// Ámbito de aplicación de un rol. Guard-rail para validar en código que no
/// se asigne un rol APP a un usuario BACKOFFICE y viceversa.
enum RoleScope {
  BACKOFFICE
  APP
  SHARED
}

/// Nivel de permiso jerárquico: cada nivel implica los anteriores.
/// NONE es un bloqueo explícito que gana sobre cualquier herencia.
enum PermissionLevel {
  NONE
  READ
  WRITE
  DELETE
  ADMIN
}

// ---------------------------------------------------------------------------
// Modelos
// ---------------------------------------------------------------------------

/// Tabla genérica de usuarios. Soporta cualquier tipo mediante el discriminador
/// `userType`. Si un tipo necesita campos propios, se añade una tabla
/// `<tipo>_profile` con FK a `user.id`.
model User {
  id            String    @id @default(uuid()) @db.Char(36)
  email         String    @unique @db.VarChar(255)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  userType      UserType  @map("user_type")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relaciones
  userRoles                   UserUserRole[]                @relation("UserRoles")
  assignedRolesByUser         UserUserRole[]                @relation("AssignedBy")
  userApiSectionPermissions   UserApiSectionPermission[]

  @@map("user")
}

/// Catálogo de roles con soporte de herencia entre roles mediante self-FK
/// `parentRoleId`. El campo `code` es inmutable y se usa como identificador
/// legible (p.ej. `admin`, `editor`).
model UserRole {
  id           String     @id @default(uuid()) @db.Char(36)
  code         String     @unique @db.VarChar(100)
  name         String     @db.VarChar(255)
  description  String?    @db.Text
  scope        RoleScope
  parentRoleId String?    @map("parent_role_id") @db.Char(36)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Self-relación para herencia entre roles
  parentRole   UserRole?  @relation("RoleInheritance", fields: [parentRoleId], references: [id])
  childRoles   UserRole[] @relation("RoleInheritance")

  // Relaciones
  userUserRoles              UserUserRole[]
  roleApiSectionPermissions  RoleApiSectionPermission[]

  @@map("user_role")
}

/// Pivot N-N entre User y UserRole. Un usuario puede tener varios roles.
/// `assignedByUserId` provee auditoría de quién asignó el rol.
model UserUserRole {
  userId           String    @map("user_id") @db.Char(36)
  userRoleId       String    @map("user_role_id") @db.Char(36)
  assignedAt       DateTime  @default(now()) @map("assigned_at")
  assignedByUserId String?   @map("assigned_by_user_id") @db.Char(36)

  // Relaciones
  user         User     @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  userRole     UserRole @relation(fields: [userRoleId], references: [id], onDelete: Restrict)
  assignedBy   User?    @relation("AssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@id([userId, userRoleId])
  @@map("user_user_role")
}

/// Catálogo jerárquico de secciones de la API. Una sección puede ser un módulo
/// (`users`), una operación (`users.create`) o una agrupación lógica.
/// La jerarquía (self-FK `parentSectionId`) es la base de la herencia de permisos.
model ApiSection {
  id              String      @id @default(uuid()) @db.Char(36)
  code            String      @unique @db.VarChar(255)
  name            String      @db.VarChar(255)
  description     String?     @db.Text
  parentSectionId String?     @map("parent_section_id") @db.Char(36)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Self-relación para jerarquía de secciones
  parentSection   ApiSection?  @relation("SectionHierarchy", fields: [parentSectionId], references: [id])
  childSections   ApiSection[] @relation("SectionHierarchy")

  // Relaciones
  roleApiSectionPermissions  RoleApiSectionPermission[]
  userApiSectionPermissions  UserApiSectionPermission[]

  @@map("api_section")
}

/// Permisos asignados a un rol sobre una sección de la API.
/// La resolución de permisos sube por `parentSectionId` y `parentRoleId`
/// (implementada en código, no aquí).
model RoleApiSectionPermission {
  userRoleId      String          @map("user_role_id") @db.Char(36)
  apiSectionId    String          @map("api_section_id") @db.Char(36)
  permissionLevel PermissionLevel @map("permission_level")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relaciones
  userRole    UserRole   @relation(fields: [userRoleId], references: [id], onDelete: Cascade)
  apiSection  ApiSection @relation(fields: [apiSectionId], references: [id], onDelete: Cascade)

  @@id([userRoleId, apiSectionId])
  @@map("role_api_section_permission")
}

/// Override de permisos por usuario sobre una sección de la API.
/// Gana sobre los permisos del rol cuando existe, incluyendo el nivel NONE
/// para bloqueo explícito.
model UserApiSectionPermission {
  userId          String          @map("user_id") @db.Char(36)
  apiSectionId    String          @map("api_section_id") @db.Char(36)
  permissionLevel PermissionLevel @map("permission_level")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relaciones
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiSection  ApiSection @relation(fields: [apiSectionId], references: [id], onDelete: Cascade)

  @@id([userId, apiSectionId])
  @@map("user_api_section_permission")
}
