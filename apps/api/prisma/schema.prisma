// Prisma schema — https://pris.ly/d/prisma-schema
//
// Notas:
// - Generador `prisma-client` (nuevo en Prisma 7, sin Rust engine). El cliente
//   se emite a `src/generated/prisma/` para que `nest build` lo compile junto
//   con el resto del código y sobreviva al `pnpm deploy` dentro de Docker.
// - El `url` ya NO va aquí. Vive en `prisma.config.ts` (CLI) y en el
//   constructor de `PrismaClient` vía driver adapter (runtime).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Discriminador de tipo de usuario. Permite un único modelo `User` con email
/// globalmente único, evitando tablas separadas por tipo.
enum UserType {
  BACKOFFICE
  APP
}

/// Ámbito de aplicación de un rol. Guard-rail para validar en código que no
/// se asigne un rol APP a un usuario BACKOFFICE y viceversa.
enum RoleScope {
  BACKOFFICE
  APP
  SHARED
}

/// Nivel de permiso jerárquico: cada nivel implica los anteriores.
/// NONE es un bloqueo explícito que gana sobre cualquier herencia.
enum PermissionLevel {
  NONE
  READ
  WRITE
  DELETE
  ADMIN
}

/// Backend de almacenamiento físico donde vive el binario de un `StoredFile`.
enum StorageDriver {
  LOCAL
  S3
  GCS
}

/// Ciclo de vida de un `StoredFile`. `PENDING` se usa en el flujo de subida
/// directa (signed upload URL) hasta que `POST /files/:id/confirm` verifica
/// que el binario llegó al backend de storage.
enum StoredFileStatus {
  PENDING
  READY
}

/// Severidad de una entrada de `ErrorLog`. Coincide 1:1 con el tipo
/// `ErrorLevel` del catálogo de errores en `src/shared/errors/error-catalog.ts`.
enum ErrorLevel {
  info
  warn
  error
  critical
}

/// Ciclo de vida editorial de un post del blog.
enum PostStatus {
  DRAFT // borrador, no visible en el listado público
  SCHEDULED // programado: se publicará cuando publishedAt <= now()
  PUBLISHED // visible públicamente
  ARCHIVED // retirado del público sin borrarlo
}

/// Cómo se dispara un workflow.
enum WorkflowTriggerKind {
  EVENT
  CRON
  MANUAL
}

/// Estado de una instancia viva (run) de un workflow.
enum WorkflowRunStatus {
  RUNNING // hay un step en curso o listo para avanzar
  WAITING // tiene PendingActions abiertas (delay / wait_for_event)
  COMPLETED
  FAILED
  CANCELED
}

/// Estado de la ejecución de un step concreto dentro de un run.
enum WorkflowStepStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

/// Tipo de trabajo diferido que procesa el scheduler (iteración posterior).
enum PendingActionKind {
  DELAY // se consume cuando runAt <= now
  WAIT_EVENT // se consume cuando llega un Event matching
  RETRY // reintento programado de un step que falló
  PENDING_START // un trigger se disparó pero maxConcurrentRuns está lleno
}

enum PendingActionStatus {
  PENDING
  CONSUMED
  CANCELED
}

/// Ámbito de un nodo del árbol de navegación de UI. Distinto de `RoleScope`:
/// aquí marcamos en qué app (`BACKOFFICE`/`APP`) se renderiza la sección, o si
/// es compartida (`SHARED`, p.ej. perfil/ajustes que existen en ambas).
enum SectionScope {
  BACKOFFICE
  APP
  SHARED
}

/// Tipo de override de acceso a una `Section`. `DENY` siempre gana sobre
/// `GRANT` (deny-by-default cuando no hay registro).
enum SectionAccessType {
  GRANT
  DENY
}

/// Estado de ciclo de vida de un formulario dinámico.
enum FormStatus {
  DRAFT // borrador, no se puede publicar instancias
  PUBLISHED // activo, se pueden crear instancias
  ARCHIVED // retirado, instancias existentes se cierran
}

/// Estado de una instancia/link público de formulario.
enum FormInstanceStatus {
  ACTIVE
  CLOSED
}

/// Política de respuesta de una instancia de formulario.
enum FormResponsePolicy {
  SINGLE_PER_LINK // una sola respuesta total por instancia
  SINGLE_PER_USER // una por usuario autenticado o fingerprint anónimo
  UNLIMITED // sin límite (salvo maxResponses)
}

/// Ciclo de vida de un lead (pipeline comercial). Ver spec `leads` §10.
enum LeadStatus {
  NEW // recién capturado, sin tocar
  CONTACTED // primer contacto hecho
  QUALIFIED // cumple criterio de calificación
  PROPOSAL // se le ha enviado propuesta/oferta
  WON // convertido (cierre positivo)
  LOST // cierre negativo
  UNQUALIFIED // descartado por no encajar
}

/// Origen por el que entró un lead.
enum LeadSource {
  WEB_FORM // vino de una FormInstance pública
  MANUAL // alta desde backoffice
  IMPORT // carga masiva
  API // integración externa
  REFERRAL // recomendación
  OTHER
}

/// Tipo de entrada del timeline de un lead.
enum LeadActivityType {
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
  SCORE_CHANGE
  FORM_SUBMISSION
  EMAIL
  CALL
  MEETING
  CONVERSION
  SYSTEM
}

/// Canal físico de entrega de una notificación. Lo define el
/// `SendingAccountType`; el resto del sistema lo deriva de ahí. Espejo del
/// enum `NotificationChannel` de `@core/shared-types`.
enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  // futuro: WHATSAPP, WEBHOOK, IN_APP…
}

// ---------------------------------------------------------------------------
// Modelos
// ---------------------------------------------------------------------------

/// Tabla genérica de usuarios. Soporta cualquier tipo mediante el discriminador
/// `userType`. Si un tipo necesita campos propios, se añade una tabla
/// `<tipo>_profile` con FK a `user.id`.
model User {
  id           String    @id @default(uuid()) @db.Char(36)
  email        String    @unique @db.VarChar(255)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  firstName    String?   @map("first_name") @db.VarChar(100)
  lastName     String?   @map("last_name") @db.VarChar(100)
  userType     UserType  @map("user_type")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Email verification
  emailVerificationToken     String?   @map("email_verification_token") @db.VarChar(128)
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")

  // Password reset
  passwordResetToken     String?   @map("password_reset_token") @db.VarChar(128)
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  // Relaciones
  userRoles                 UserUserRole[]             @relation("UserRoles")
  assignedRolesByUser       UserUserRole[]             @relation("AssignedBy")
  userApiSectionPermissions UserApiSectionPermission[]
  storedFiles               StoredFile[]
  posts                     Post[]
  sectionAccess             UserSectionAccess[]
  dashboards                Dashboard[]

  @@map("user")
}

/// Catálogo de roles con soporte de herencia entre roles mediante self-FK
/// `parentRoleId`. El campo `code` es inmutable y se usa como identificador
/// legible (p.ej. `admin`, `editor`).
model UserRole {
  id           String    @id @default(uuid()) @db.Char(36)
  code         String    @unique @db.VarChar(100)
  name         String    @db.VarChar(255)
  description  String?   @db.Text
  scope        RoleScope
  parentRoleId String?   @map("parent_role_id") @db.Char(36)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Self-relación para herencia entre roles
  parentRole UserRole?  @relation("RoleInheritance", fields: [parentRoleId], references: [id])
  childRoles UserRole[] @relation("RoleInheritance")

  // Relaciones
  userUserRoles             UserUserRole[]
  roleApiSectionPermissions RoleApiSectionPermission[]
  sectionAccess             RoleSectionAccess[]

  @@map("user_role")
}

/// Pivot N-N entre User y UserRole. Un usuario puede tener varios roles.
/// `assignedByUserId` provee auditoría de quién asignó el rol.
model UserUserRole {
  userId           String   @map("user_id") @db.Char(36)
  userRoleId       String   @map("user_role_id") @db.Char(36)
  assignedAt       DateTime @default(now()) @map("assigned_at")
  assignedByUserId String?  @map("assigned_by_user_id") @db.Char(36)

  // Relaciones
  user       User     @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  userRole   UserRole @relation(fields: [userRoleId], references: [id], onDelete: Restrict)
  assignedBy User?    @relation("AssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@id([userId, userRoleId])
  @@map("user_user_role")
}

/// Catálogo jerárquico de secciones de la API. Una sección puede ser un módulo
/// (`users`), una operación (`users.create`) o una agrupación lógica.
/// La jerarquía (self-FK `parentSectionId`) es la base de la herencia de permisos.
model ApiSection {
  id              String   @id @default(uuid()) @db.Char(36)
  code            String   @unique @db.VarChar(255)
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  parentSectionId String?  @map("parent_section_id") @db.Char(36)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Self-relación para jerarquía de secciones
  parentSection ApiSection?  @relation("SectionHierarchy", fields: [parentSectionId], references: [id])
  childSections ApiSection[] @relation("SectionHierarchy")

  // Relaciones
  roleApiSectionPermissions RoleApiSectionPermission[]
  userApiSectionPermissions UserApiSectionPermission[]

  @@map("api_section")
}

/// Permisos asignados a un rol sobre una sección de la API.
/// La resolución de permisos sube por `parentSectionId` y `parentRoleId`
/// (implementada en código, no aquí).
model RoleApiSectionPermission {
  userRoleId      String          @map("user_role_id") @db.Char(36)
  apiSectionId    String          @map("api_section_id") @db.Char(36)
  permissionLevel PermissionLevel @map("permission_level")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relaciones
  userRole   UserRole   @relation(fields: [userRoleId], references: [id], onDelete: Cascade)
  apiSection ApiSection @relation(fields: [apiSectionId], references: [id], onDelete: Cascade)

  @@id([userRoleId, apiSectionId])
  @@map("role_api_section_permission")
}

/// Override de permisos por usuario sobre una sección de la API.
/// Gana sobre los permisos del rol cuando existe, incluyendo el nivel NONE
/// para bloqueo explícito.
model UserApiSectionPermission {
  userId          String          @map("user_id") @db.Char(36)
  apiSectionId    String          @map("api_section_id") @db.Char(36)
  permissionLevel PermissionLevel @map("permission_level")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relaciones
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiSection ApiSection @relation(fields: [apiSectionId], references: [id], onDelete: Cascade)

  @@id([userId, apiSectionId])
  @@map("user_api_section_permission")
}

/// Metadata de un fichero subido a través del módulo storage. El binario vive
/// en disco local (dev) o en un bucket (pre/pro) según `driver`; esta tabla
/// nunca guarda el contenido, solo dónde encontrarlo (`storageKey`).
/// Borrado lógico vía `deletedAt`; el purgado físico es un job aparte.
model StoredFile {
  id           String           @id @default(uuid()) @db.Char(36)
  ownerUserId  String?          @map("owner_user_id") @db.Char(36)
  originalName String           @map("original_name") @db.VarChar(255)
  mimeType     String           @map("mime_type") @db.VarChar(127)
  sizeBytes    Int              @map("size_bytes")
  driver       StorageDriver
  status       StoredFileStatus @default(READY)
  storageKey   String           @map("storage_key") @db.VarChar(512)
  deletedAt    DateTime?        @map("deleted_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relaciones
  owner User? @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@map("stored_file")
}

/// Auditoría de errores capturados por `AppExceptionFilter`. Se escribe de
/// forma asíncrona (no bloquea la respuesta al cliente) para cualquier error
/// con `level` >= `warn` — los `info` no se persisten para no inflar la tabla.
/// `errorId` correlaciona la respuesta al cliente ↔ los logs de Docker ↔ esta fila.
model ErrorLog {
  id         String     @id @default(uuid()) @db.Char(36)
  errorId    String     @unique @map("error_id") @db.Char(36)
  code       String     @db.VarChar(100)
  level      ErrorLevel
  httpStatus Int        @map("http_status")
  message    String     @db.Text
  path       String?    @db.VarChar(255)
  method     String?    @db.VarChar(10)
  userId     String?    @map("user_id") @db.Char(36)
  context    Json?
  stack      String?    @db.LongText
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([code])
  @@index([level])
  @@index([createdAt])
  @@index([userId])
  @@map("error_log")
}

// ---------------------------------------------------------------------------
// Blog de noticias (módulo `blog`)
// ---------------------------------------------------------------------------

/// Artículo del blog de noticias. Es la entidad central; su cuerpo vive en
/// `content` (Markdown/HTML renderizado por el front). La portada referencia
/// un `StoredFile` del módulo storage por id (FK suave, sin `@relation`).
model Post {
  id           String     @id @default(uuid()) @db.Char(36)
  slug         String     @unique @db.VarChar(180) // identificador legible para la URL pública
  title        String     @db.VarChar(200)
  excerpt      String?    @db.VarChar(320) // resumen/dek para listados y SEO
  content      String     @db.LongText // cuerpo del artículo (Markdown/HTML)
  status       PostStatus @default(DRAFT)
  publishedAt  DateTime?  @map("published_at") // fecha de publicación (o de programación)
  coverImageId String?    @map("cover_image_id") @db.Char(36) // FK suave a StoredFile (módulo storage)
  authorId     String?    @map("author_id") @db.Char(36)

  // SEO
  metaTitle       String? @map("meta_title") @db.VarChar(200)
  metaDescription String? @map("meta_description") @db.VarChar(320)

  // Métricas
  viewCount Int @default(0) @map("view_count")

  categoryId String? @map("category_id") @db.Char(36)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  author   User?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category PostCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags     PostTagOnPost[]

  @@index([status, publishedAt]) // listado público ordenado por fecha
  @@index([categoryId])
  @@index([authorId])
  @@map("post")
}

/// Categoría jerárquica del blog (self-FK opcional para subcategorías).
/// Un post tiene 0..1 categoría.
model PostCategory {
  id          String   @id @default(uuid()) @db.Char(36)
  slug        String   @unique @db.VarChar(140)
  name        String   @db.VarChar(140)
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Char(36)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Self-relación para subcategorías
  parent   PostCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children PostCategory[] @relation("CategoryHierarchy")

  posts Post[]

  @@map("post_category")
}

/// Etiqueta transversal del blog. Un post tiene 0..N etiquetas.
model PostTag {
  id        String   @id @default(uuid()) @db.Char(36)
  slug      String   @unique @db.VarChar(140)
  name      String   @db.VarChar(140)
  createdAt DateTime @default(now()) @map("created_at")

  postTags PostTagOnPost[]

  @@map("post_tag")
}

/// Pivot N-N explícito entre Post y PostTag. Se deja explícito (en vez de la
/// N-N implícita de Prisma) para poder añadir metadatos al vínculo y controlar
/// el nombre de la tabla.
model PostTagOnPost {
  postId String @map("post_id") @db.Char(36)
  tagId  String @map("tag_id") @db.Char(36)

  post Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tag_on_post")
}

// ---------------------------------------------------------------------------
// Motor de eventos y workflows (módulo `workflows`)
// ---------------------------------------------------------------------------

/// Hecho ocurrido en el sistema, inmutable y auditable. Reentra al motor por
/// `RegisterEventUseCase`. `sourceUserId` es una FK suave (sin `@relation`).
model WorkflowEvent {
  id             String   @id @default(uuid()) @db.Char(36)
  type           String   @db.VarChar(120) // "user.signed_up"
  payload        Json
  sourceUserId   String?  @map("source_user_id") @db.Char(36)
  correlationId  String?  @map("correlation_id") @db.Char(36)
  idempotencyKey String?  @map("idempotency_key") @db.VarChar(120)
  occurredAt     DateTime @default(now()) @map("occurred_at")

  triggeredRuns WorkflowRun[]   @relation("WorkflowRunTrigger")
  consumedBy    PendingAction[] @relation("PendingActionConsumedEvent")

  @@unique([idempotencyKey]) // sparse: NULL permitido
  @@index([type, occurredAt])
  @@index([sourceUserId])
  @@index([correlationId])
  @@map("workflow_event")
}

/// Blueprint de un workflow + su DSL (JSON). Identificado por `key` + `version`.
/// Una sola versión activa por `key`.
model WorkflowDefinition {
  id          String    @id @default(uuid()) @db.Char(36)
  key         String    @db.VarChar(120)
  version     Int
  name        String    @db.VarChar(200)
  description String?   @db.Text
  dsl         Json // ver spec §4
  isActive    Boolean   @default(false) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  triggers       WorkflowTrigger[]
  runs           WorkflowRun[]
  pendingActions PendingAction[]

  @@unique([key, version])
  @@index([key, isActive])
  @@map("workflow_definition")
}

/// Cómo se dispara una definición: por evento, cron o manual.
model WorkflowTrigger {
  id           String              @id @default(uuid()) @db.Char(36)
  definitionId String              @map("definition_id") @db.Char(36)
  kind         WorkflowTriggerKind

  // kind = EVENT
  eventType       String? @map("event_type") @db.VarChar(120)
  matchExpression Json?   @map("match_expression") // mini DSL spec §4.3

  // kind = CRON
  cronExpression String?   @map("cron_expression") @db.VarChar(60) // 5 campos UTC
  cronPayload    Json?     @map("cron_payload")
  nextFireAt     DateTime? @map("next_fire_at")

  // Target (fan-out): sobre qué entidades corre. NULL = un único run global.
  target Json? // { type, filter? } — mini DSL spec §4.4

  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)

  @@index([kind, eventType])
  @@index([kind, nextFireAt])
  @@index([definitionId])
  @@map("workflow_trigger")
}

/// Instancia viva de un workflow, con estado, contexto y cursor de step.
/// Todo el estado vive aquí para sobrevivir a reinicios.
model WorkflowRun {
  id             String            @id @default(uuid()) @db.Char(36)
  definitionId   String            @map("definition_id") @db.Char(36) // congelado (versión incluida)
  triggerEventId String?           @map("trigger_event_id") @db.Char(36)
  status         WorkflowRunStatus @default(RUNNING)
  context        Json              @default("{}")
  currentStepKey String?           @map("current_step_key") @db.VarChar(120)
  isDryRun       Boolean           @default(false) @map("is_dry_run")
  startedAt      DateTime          @default(now()) @map("started_at")
  finishedAt     DateTime?         @map("finished_at")
  lastError      String?           @map("last_error") @db.Text

  // Lock optimista del worker (iteración posterior):
  lockedBy    String?   @map("locked_by") @db.VarChar(80)
  lockedUntil DateTime? @map("locked_until")

  definition     WorkflowDefinition      @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  triggerEvent   WorkflowEvent?          @relation("WorkflowRunTrigger", fields: [triggerEventId], references: [id])
  steps          WorkflowStepExecution[]
  pendingActions PendingAction[]

  @@index([status])
  @@index([definitionId, status])
  @@index([lockedUntil])
  @@map("workflow_run")
}

/// Registro auditado de un step ejecutado dentro de un run.
model WorkflowStepExecution {
  id         String             @id @default(uuid()) @db.Char(36)
  runId      String             @map("run_id") @db.Char(36)
  stepKey    String             @map("step_key") @db.VarChar(120)
  actionKey  String             @map("action_key") @db.VarChar(120)
  status     WorkflowStepStatus @default(PENDING)
  attempt    Int                @default(1)
  input      Json?
  output     Json?
  error      String?            @db.Text
  startedAt  DateTime           @default(now()) @map("started_at")
  finishedAt DateTime?          @map("finished_at")

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, startedAt])
  @@map("workflow_step_execution")
}

/// Trabajo diferido (delay / wait_for_event / retry / arranque encolado). Lo
/// procesa el scheduler (iteración posterior). Se modela ya para no migrar luego.
model PendingAction {
  id              String              @id @default(uuid()) @db.Char(36)
  runId           String?             @map("run_id") @db.Char(36) // NULL si kind = PENDING_START
  definitionId    String?             @map("definition_id") @db.Char(36) // SET si kind = PENDING_START
  triggerEventId  String?             @map("trigger_event_id") @db.Char(36)
  stepKey         String?             @map("step_key") @db.VarChar(120)
  kind            PendingActionKind
  status          PendingActionStatus @default(PENDING)
  runAt           DateTime?           @map("run_at")
  eventType       String?             @map("event_type") @db.VarChar(120)
  matchExpression Json?               @map("match_expression")
  // Entidad target ya resuelta (fan-out) para kind = PENDING_START, de modo que
  // el consumidor reanude el run sobre ESA entidad. NULL = run sin target.
  target          Json?
  consumedEventId String?             @map("consumed_event_id") @db.Char(36)
  createdAt       DateTime            @default(now()) @map("created_at")
  consumedAt      DateTime?           @map("consumed_at")

  run           WorkflowRun?        @relation(fields: [runId], references: [id], onDelete: Cascade)
  definition    WorkflowDefinition? @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  consumedEvent WorkflowEvent?      @relation("PendingActionConsumedEvent", fields: [consumedEventId], references: [id])

  @@index([status, runAt])
  @@index([status, eventType])
  @@index([status, kind, definitionId, createdAt])
  @@index([runId])
  @@map("workflow_pending_action")
}

/// Nodo del árbol de navegación de UI. `code` es el slug legible
/// (`users`, `iam.users`, `settings.general`). Self-FK `parentId` modela el
/// árbol. `apiRequirements` es la lista de códigos de `ApiSection` que el
/// usuario debe poder consumir para que la sección aparezca — sólo es una
/// conveniencia (la seguridad real la hace el guard de cada endpoint).
model Section {
  id              String       @id @default(uuid()) @db.Char(36)
  code            String       @db.VarChar(255)
  name            String       @db.VarChar(255)
  icon            String?      @db.VarChar(100)
  route           String?      @db.VarChar(500)
  parentId        String?      @map("parent_id") @db.Char(36)
  scope           SectionScope
  order           Int          @default(0)
  isActive        Boolean      @default(true) @map("is_active")
  apiRequirements Json?        @map("api_requirements")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  parent     Section?            @relation("SectionTree", fields: [parentId], references: [id])
  children   Section[]           @relation("SectionTree")
  roleAccess RoleSectionAccess[]
  userAccess UserSectionAccess[]

  @@unique([code, scope])
  @@index([scope, isActive, order])
  @@index([parentId])
  @@map("section")
}

/// Override de visibilidad de una `Section` para un rol. Si una sección tiene
/// `DENY` en algún rol del usuario, no se muestra. `GRANT` la hace visible
/// salvo que otro registro la deniegue. Sin registros → sección oculta.
model RoleSectionAccess {
  userRoleId String            @map("user_role_id") @db.Char(36)
  sectionId  String            @map("section_id") @db.Char(36)
  access     SectionAccessType
  createdAt  DateTime          @default(now()) @map("created_at")

  userRole UserRole @relation(fields: [userRoleId], references: [id], onDelete: Cascade)
  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([userRoleId, sectionId])
  @@index([sectionId])
  @@map("role_section_access")
}

/// Override de visibilidad de una `Section` para un usuario concreto. Tiene
/// prioridad sobre los registros de rol — útil para excepciones puntuales.
model UserSectionAccess {
  userId    String            @map("user_id") @db.Char(36)
  sectionId String            @map("section_id") @db.Char(36)
  access    SectionAccessType
  createdAt DateTime          @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([userId, sectionId])
  @@index([sectionId])
  @@map("user_section_access")
}

// ---------------------------------------------------------------------------
// Formularios dinámicos (módulo `dynamic-forms`)
// ---------------------------------------------------------------------------

/// Definición de un formulario dinámico. El `schema` es JSON que describe
/// los campos (tipo, validaciones, condiciones). Se almacena como JSON para
/// ser consumido por el renderer del frontend sin acoplamiento al backend.
model Form {
  id          String     @id @default(uuid()) @db.Char(36)
  title       String     @db.VarChar(200)
  description String?    @db.Text
  schema      Json // estructura declarativa de campos (ver TASK-92 §schema)
  status      FormStatus @default(DRAFT)
  createdById String?    @map("created_by_id") @db.Char(36) // FK suave a User
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  instances FormInstance[]

  @@index([status])
  @@index([createdById])
  @@map("form")
}

/// Link público de un formulario. Cada instancia tiene un `hash` opaco que
/// se incluye en la URL y permite configurar política, ventana y límites
/// de forma independiente para cada distribución del mismo formulario.
model FormInstance {
  id             String             @id @default(uuid()) @db.Char(36)
  formId         String             @map("form_id") @db.Char(36)
  hash           String             @unique @db.VarChar(64) // token URL-safe, ≥32 chars
  responsePolicy FormResponsePolicy @default(UNLIMITED) @map("response_policy")
  requiresAuth   Boolean            @default(false) @map("requires_auth")
  opensAt        DateTime?          @map("opens_at")
  closesAt       DateTime?          @map("closes_at")
  maxResponses   Int?               @map("max_responses") // cap global, null = sin límite
  status         FormInstanceStatus @default(ACTIVE)
  createdById    String?            @map("created_by_id") @db.Char(36) // FK suave a User
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  form      Form           @relation(fields: [formId], references: [id], onDelete: Cascade)
  responses FormResponse[]

  @@index([formId])
  @@index([hash])
  @@index([status, closesAt])
  @@map("form_instance")
}

/// Respuesta enviada por un usuario (o anónimo) a una instancia de formulario.
/// `answers` guarda el mapa fieldKey→value validado. `schemaSnapshot` preserva
/// el schema vigente en el momento del envío para mantener coherencia si el
/// formulario cambia después.
model FormResponse {
  id                     String   @id @default(uuid()) @db.Char(36)
  formInstanceId         String   @map("form_instance_id") @db.Char(36)
  submittedById          String?  @map("submitted_by_id") @db.Char(36) // null si anónimo
  submittedByFingerprint String?  @map("submitted_by_fingerprint") @db.VarChar(128) // hash IP+UA para anónimos
  answers                Json // mapa fieldKey → value
  schemaSnapshot         Json     @map("schema_snapshot") // copia del schema al enviar
  submittedAt            DateTime @default(now()) @map("submitted_at")
  ipAddress              String?  @map("ip_address") @db.VarChar(45)
  userAgent              String?  @map("user_agent") @db.VarChar(512)

  formInstance FormInstance @relation(fields: [formInstanceId], references: [id], onDelete: Cascade)

  @@index([formInstanceId, submittedAt])
  @@index([submittedById])
  @@map("form_response")
}

enum WidgetType {
  KPI_CARD
  LINE
  BAR
  AREA
  GAUGE
}

/// Dashboard personalizado por usuario. Cada usuario tiene al menos uno
/// marcado como default. Los widgets definen el layout (grid react-grid-layout).
model Dashboard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Char(36)
  name      String   @db.VarChar(255)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets DashboardWidget[]

  @@index([userId])
  @@map("dashboard")
}

/// Widget dentro de un dashboard. La posición y tamaño siguen el sistema de
/// react-grid-layout (columnas x, fila y, ancho w, alto h). `config` es JSON
/// libre para customización futura (título, color, rango).
model DashboardWidget {
  id          String     @id @default(cuid())
  dashboardId String     @map("dashboard_id")
  kpiSlug     String     @map("kpi_slug") @db.VarChar(100)
  widgetType  WidgetType @map("widget_type")
  x           Int
  y           Int
  w           Int
  h           Int
  config      Json?
  order       Int        @default(0)

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("dashboard_widget")
}

// ---------------------------------------------------------------------------
// Leads (módulo `leads`)
// ---------------------------------------------------------------------------

/// Contacto comercial potencial y su estado en el pipeline. Las FK a `User` y a
/// `FormResponse` son suaves (columna sin `@relation`) para no acoplar el módulo
/// ni romper el histórico al borrar un usuario. Ver spec `leads`.
model Lead {
  id String @id @default(uuid()) @db.Char(36)

  // Identidad del contacto
  email           String? @db.VarChar(255)
  emailNormalized String? @map("email_normalized") @db.VarChar(255) // lower+trim para dedupe
  phone           String? @db.VarChar(40)
  firstName       String? @map("first_name") @db.VarChar(100)
  lastName        String? @map("last_name") @db.VarChar(100)
  company         String? @db.VarChar(160)

  // Ciclo de vida
  status  LeadStatus @default(NEW)
  score   Int        @default(0)
  ownerId String?    @map("owner_id") @db.Char(36) // FK suave a User

  // Atribución / origen
  source         LeadSource @default(OTHER)
  formResponseId String?    @map("form_response_id") @db.Char(36) // FK suave a FormResponse
  utmSource      String?    @map("utm_source") @db.VarChar(120)
  utmMedium      String?    @map("utm_medium") @db.VarChar(120)
  utmCampaign    String?    @map("utm_campaign") @db.VarChar(120)

  // Datos flexibles
  customFields Json? @map("custom_fields")

  // Consentimiento (GDPR)
  consentGiven Boolean   @default(false) @map("consent_given")
  consentAt    DateTime? @map("consent_at")

  // Conversión
  convertedToUserId String?   @map("converted_to_user_id") @db.Char(36) // FK suave a User
  convertedAt       DateTime? @map("converted_at")

  createdById String?  @map("created_by_id") @db.Char(36) // FK suave a User
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  activities LeadActivity[]
  tags       LeadTagOnLead[]

  @@index([status, createdAt])
  @@index([ownerId, status])
  @@index([emailNormalized])
  @@index([source])
  @@map("lead")
}

/// Entrada de timeline de un lead. Inmutable: solo se añade, nunca se edita.
model LeadActivity {
  id      String           @id @default(uuid()) @db.Char(36)
  leadId  String           @map("lead_id") @db.Char(36)
  type    LeadActivityType
  body    String?          @db.Text
  meta    Json?
  actorId String?          @map("actor_id") @db.Char(36) // FK suave a User (null = sistema)

  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("lead_activity")
}

/// Catálogo de etiquetas de leads.
model LeadTag {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @unique @db.VarChar(80)
  color     String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  leads LeadTagOnLead[]

  @@map("lead_tag")
}

/// Join N:N entre leads y etiquetas.
model LeadTagOnLead {
  leadId String @map("lead_id") @db.Char(36)
  tagId  String @map("tag_id") @db.Char(36)

  lead Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  LeadTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@index([tagId])
  @@map("lead_tag_on_lead")
}

// ---------------------------------------------------------------------------
// Notificaciones (cuentas de envío + tipos de mensaje)
// ---------------------------------------------------------------------------

/// Tipo de cuenta de envío. Define un `channel` y dos contratos declarativos:
/// `configSchema` (qué campos necesita configurar una `SendingAccount` de este
/// tipo: credenciales, remitente…) y `messageSchema` (qué campos de contenido
/// pide un `MessageType` de este canal). Son descriptores de campos (misma
/// idea que el schema de los formularios dinámicos) que dirigen el render del
/// backoffice; la validación server-side usa el catálogo de canales en código.
/// Mayormente semilla/administración.
model SendingAccountType {
  id            String              @id @default(uuid()) @db.Char(36)
  key           String              @unique @db.VarChar(60) // "email", "sms", "push"
  name          String              @db.VarChar(120)
  channel       NotificationChannel
  configSchema  Json                @map("config_schema") // descriptores de config de la cuenta
  messageSchema Json                @map("message_schema") // descriptores del contenido del mensaje
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  accounts SendingAccount[]

  @@index([channel])
  @@map("sending_account_type")
}

/// Cuenta de envío concreta y configurada de un tipo. Ej: "Resend — producción".
/// `config` se valida contra el catálogo del canal; los campos marcados como
/// secretos (apiKey, authToken…) se guardan cifrados en reposo.
model SendingAccount {
  id        String   @id @default(uuid()) @db.Char(36)
  typeId    String   @map("type_id") @db.Char(36)
  name      String   @db.VarChar(160)
  config    Json // validado contra el catálogo del tipo; secretos cifrados
  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  type         SendingAccountType @relation(fields: [typeId], references: [id], onDelete: Restrict)
  messageTypes MessageType[]

  @@index([typeId])
  @@map("sending_account")
}

/// Tipo de mensaje. Selecciona una `SendingAccount` (⇒ hereda su canal) y
/// guarda en `content` los campos propios de ese canal (subject/html para
/// email, body para SMS, title/body para push). Admite plantillas `{{ var }}`
/// que se renderizan en el momento del envío contra el contexto del workflow.
model MessageType {
  id        String   @id @default(uuid()) @db.Char(36)
  key       String   @unique @db.VarChar(120) // "welcome_email"
  name      String   @db.VarChar(160)
  accountId String   @map("account_id") @db.Char(36)
  content   Json // validado contra el messageSchema del canal; admite plantillas
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account SendingAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId])
  @@map("message_type")
}
