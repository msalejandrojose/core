# Plantilla del `.env` (que SÍ va gitignored). Copia este archivo:
#   cp apps/api/.env.example apps/api/.env
# y ajusta los valores. Los defaults no-secretos están en `.env.local`.

# Credenciales BBDD (deben coincidir con docker/.env)
DB_USER=core
DB_PASSWORD=core

# Prisma — connection string completa. Debe ser coherente con DB_USER/DB_PASSWORD
# y con docker/.env. Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://core:core@localhost:3306/core"

# Cuando metamos auth:
# JWT_SECRET=
