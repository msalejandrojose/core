# Plantilla del `.env` (que SÍ va gitignored). Copia este archivo:
#   cp apps/api/.env.example apps/api/.env
# y ajusta los valores. Los defaults no-secretos están en `.env.local`.

# Credenciales BBDD (deben coincidir con docker/.env)
DB_USER=core
DB_PASSWORD=core

# Prisma — connection string completa. Debe ser coherente con DB_USER/DB_PASSWORD
# y con docker/.env. Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://core:core@localhost:3306/core"

# Solo desarrollo: Prisma usa una "shadow DB" para detectar drift al correr
# `prisma migrate dev`. Necesita un usuario con permiso CREATE DATABASE.
# En prod usamos `prisma migrate deploy` que NO necesita shadow.
SHADOW_DATABASE_URL="mysql://root:root@localhost:3306/_core_shadow"

# Secreto para firmar JWTs. Generar con: openssl rand -base64 48
JWT_SECRET=

# Cuando metamos auth:
# JWT_SECRET=

# Resend — proveedor de email transaccional (https://resend.com/api-keys)
MAIL_API_KEY=    # API key de Resend
MAIL_FROM=       # Remitente. Ej: Core <noreply@tudominio.com>

# URL base para generar enlaces en emails de verificación / reset
APP_URL=https://tudominio.com

# Notificaciones — clave para cifrar en reposo los secretos de las cuentas de
# envío (apiKey, authToken…). 32 bytes en hex (64 chars) o base64.
# Genera una con: openssl rand -hex 32
# Sin definir → los secretos NO se cifran (solo aceptable en dev/CI).
NOTIFICATIONS_ENC_KEY=

# Notificaciones — clave pública (base64 DER/SPKI) del Event Webhook de SendGrid
# para verificar la firma de los eventos de entrega (delivered/bounce/open…).
# Se obtiene al activar el Signed Event Webhook en el panel de SendGrid.
# Sin definir → la firma del webhook NO se verifica (solo aceptable en dev/CI).
SENDGRID_WEBHOOK_PUBLIC_KEY=

# Storage — solo necesario si STORAGE_DRIVER=S3 (ver .env.local)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
# Solo para apuntar a MinIO/R2 en vez del S3 real:
# STORAGE_S3_ENDPOINT=http://localhost:9000
# STORAGE_S3_FORCE_PATH_STYLE=true
