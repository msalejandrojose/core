# Plantilla de variables de entorno del backoffice.
#
#   .env        -> valores NO-secretos (URLs, endpoints). SE COMMITEA.
#   .env.local  -> secretos / overrides locales. GITIGNORED, nunca se commitea.
#
# Copia las claves que necesites a tu .env / .env.local.

# URL base de la API (@core/api). No es secreto.
VITE_API_URL=http://localhost:3000
