# Defaults NO-secretos compartidos por el equipo. Committed (excepción al
# patrón Vite/Astro estándar, donde .env.local suele ser el gitignored — ver
# README de apps/web). Vite carga este archivo DESPUÉS de `.env` y sobrescribe
# claves repetidas, así que aquí NUNCA van variables PUBLIC_* (eso vive en tu
# .env local, ver .env.example) — solo config de despliegue que no cambia entre
# desarrolladores.

# Proyecto de Cloudflare Pages donde deploy-web.yml publica apps/web/dist.
CLOUDFLARE_PROJECT_NAME=core-web
