# URL pública de la API (expuesta al cliente, prefijo PUBLIC_ obligatorio en Astro/Vite)
PUBLIC_API_URL=http://api.aj-local.es

# URL pública del sitio (usada en sitemap y OG tags)
PUBLIC_SITE_URL=http://www.aj-local.es

# Hash de la FormInstance de captación de leads (lo imprime `seed:leads`).
# La página /captacion renderiza ese formulario y su envío dispara el workflow
# que crea el lead.
PUBLIC_LEADS_FORM_HASH=
