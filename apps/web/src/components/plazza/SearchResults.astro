---
import { searchParkings, resolvePhotoUrl } from '../../lib/parking';

// Teaser estático (build-time) con las últimas plazas publicadas. El
// buscador vivo, con fechas y disponibilidad real, vive en /plazas
// (isla `ParkingSearch`).
const page = await searchParkings({ limit: 3 });
const results = page.data;
---
<section class="py-20 md:py-28 px-5 md:px-10 bg-white border-t border-ink/8">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex items-end justify-between gap-6 mb-10 md:mb-14 reveal">
      <div class="max-w-[560px]">
        <p class="eyebrow mb-4">Últimas plazas publicadas</p>
        <h2 class="font-plazza text-[clamp(26px,3.4vw,40px)] leading-[1.08] [letter-spacing:var(--tracking-tighter)] font-semibold">
          Plazas disponibles cerca de ti.
        </h2>
      </div>
      <a href="/plazas" class="hidden md:block font-mono text-[12px] text-ink/40 uppercase tracking-[0.12em] hover:text-ink transition">
        Ver todas las plazas →
      </a>
    </div>

    {results.length === 0 ? (
      <p class="text-[15px] text-ink/50 reveal">
        Todavía no hay plazas publicadas. <a href="/contacto" class="text-amber-dark font-semibold">Publica la tuya</a>.
      </p>
    ) : (
      <div class="grid md:grid-cols-3 gap-6 md:gap-7">
        {results.map((r, i) => (
          <a
            href={`/plazas/${r.id}`}
            class="card-hover rounded-xl overflow-hidden border border-ink/8 bg-paper reveal block"
            style={`transition-delay: ${i * 0.08}s`}
          >
            <div
              class="plaza-ph aspect-[4/3] relative"
              style={r.coverPhotoUrl ? `background-image:url(${resolvePhotoUrl(r.coverPhotoUrl)}); background-size:cover; background-position:center;` : ''}
            ></div>
            <div class="p-5">
              <h3 class="font-plazza font-semibold text-[17px] tracking-tight text-ink mb-1.5">{r.title}</h3>
              <p class="text-[14px] text-ink/55 mb-4">{r.address}</p>
              <div class="flex items-baseline justify-between">
                <p class="font-plazza font-semibold text-[20px] text-ink">
                  {r.pricePerDay}€ <span class="font-sans font-normal text-[13px] text-ink/50">/ día</span>
                </p>
                <span class="text-[13px] font-semibold text-amber-dark">Ver ficha →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    <a href="/plazas" class="md:hidden mt-8 block text-center font-mono text-[12px] text-ink/40 uppercase tracking-[0.12em]">
      Ver todas las plazas →
    </a>
  </div>
</section>
