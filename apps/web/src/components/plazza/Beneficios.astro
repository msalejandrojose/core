---
const benefits = [
  {
    title: 'Hasta 70% más barato',
    body: 'Que un parking tradicional en zonas de eventos o centro ciudad.',
    icon: 'M2 12 4 6h8l2 6M2 12v3h1.5m9 0H13v-3M2 12h12M4.5 15a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm7 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z',
  },
  {
    title: 'Pagas por lo que usas',
    body: 'Por horas o por días, sin abonos ni permanencias.',
    icon: 'M8 2v12M4 5h6.5a2 2 0 0 1 0 4H5.5a2 2 0 0 0 0 4H12',
  },
  {
    title: 'Rentabiliza tu plaza',
    body: 'Gana dinero con las horas en que no la usas.',
    icon: 'M2 10 6 6l3 3 5-5M14 4v4h-4',
  },
  {
    title: 'Pago y acceso seguros',
    body: 'Identidad verificada y cancelación flexible.',
    icon: 'M8 1.5 13 3.5v4c0 3.5-2.2 6-5 7-2.8-1-5-3.5-5-7v-4Z',
  },
];
---
<section class="py-20 md:py-28 px-5 md:px-10 border-t border-ink/8">
  <div class="max-w-[1280px] mx-auto">
    <div class="max-w-[640px] mb-14 md:mb-20 reveal">
      <p class="eyebrow mb-4">Por qué Plazza</p>
      <h2 class="font-plazza text-[clamp(26px,3.4vw,40px)] leading-[1.08] [letter-spacing:var(--tracking-tighter)] font-semibold">
        Aparcar no debería ser una lotería.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-ink/8 border border-ink/8 rounded-lg overflow-hidden">
      {benefits.map(({ title, body, icon }, i) => (
        <div class="bg-white p-7 card-hover reveal" style={`transition-delay: ${i * 0.06}s`}>
          <svg width="24" height="20" viewBox="0 0 16 16" fill="none" stroke="#F5A623" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={icon} />
          </svg>
          <h3 class="font-plazza text-[17px] font-medium tracking-tight mt-5 mb-2">{title}</h3>
          <p class="text-[14px] leading-[1.55] text-ink/60">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
