---
const amenities = [
  { label: 'Techada', detail: 'Protegida de lluvia y sol' },
  { label: 'Vigilancia 24h', detail: 'Cámaras en el acceso' },
  { label: 'Acceso con app', detail: 'Sin llaves ni mandos físicos' },
  { label: 'Altura máx. 2,1 m', detail: 'Válida para SUV y furgonetas pequeñas' },
];
---
<section id="ficha" class="py-20 md:py-28 px-5 md:px-10 border-t border-ink/8">
  <div class="max-w-[1280px] mx-auto">
    <p class="eyebrow mb-4 reveal">Ficha de plaza</p>
    <h2 class="font-plazza text-[clamp(26px,3.4vw,40px)] leading-[1.08] [letter-spacing:var(--tracking-tighter)] font-semibold mb-10 md:mb-14 reveal max-w-[640px]">
      Toda la información antes de reservar.
    </h2>

    <div class="grid lg:grid-cols-12 gap-8 lg:gap-14">
      <!-- Galería -->
      <div class="lg:col-span-7 reveal">
        <div class="grid grid-cols-3 grid-rows-2 gap-2.5 h-[320px] md:h-[420px]">
          <div class="plaza-ph col-span-2 row-span-2 rounded-lg" aria-hidden="true"></div>
          <div class="plaza-ph rounded-lg" aria-hidden="true"></div>
          <div class="plaza-ph rounded-lg" aria-hidden="true"></div>
        </div>

        <div class="mt-8 flex items-start justify-between gap-6 flex-wrap">
          <div>
            <h3 class="font-plazza font-semibold text-[22px] tracking-tight text-ink mb-1.5">
              Plaza P12 · Parking Recinto Norte
            </h3>
            <p class="text-[15px] text-ink/60">A 250 m del acceso principal al estadio · Sótano -1</p>
          </div>
          <span class="flex items-center gap-1.5 rounded-full bg-signal/10 text-signal text-[13px] font-semibold px-3 py-1.5">
            <span class="block w-[6px] h-[6px] rounded-full bg-signal" aria-hidden="true"></span>
            Disponible
          </span>
        </div>

        <p class="mt-5 text-[15px] leading-[1.6] text-ink/65 max-w-[560px]">
          Plaza privada en parking subterráneo, ideal para eventos en el recinto. Entrada y salida
          controladas con la app, sin esperar a ningún encargado. El propietario confirma la reserva
          en menos de una hora.
        </p>

        <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-5">
          {amenities.map((a) => (
            <div class="flex items-start gap-2.5">
              <svg class="mt-0.5 shrink-0" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                <circle cx="7.5" cy="7.5" r="7" stroke="#F5A623" stroke-width="1.4" />
                <path d="M4.5 7.7 6.6 9.8 10.5 5.5" stroke="#F5A623" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <div>
                <dt class="text-[14px] font-medium text-ink">{a.label}</dt>
                <dd class="text-[13px] text-ink/50">{a.detail}</dd>
              </div>
            </div>
          ))}
        </dl>
      </div>

      <!-- Reserva -->
      <div class="lg:col-span-5 reveal" style="transition-delay: .1s">
        <div class="rounded-xl border border-ink/10 bg-white p-6 md:p-7 lg:sticky lg:top-24">
          <div class="flex items-baseline justify-between mb-6">
            <p class="font-plazza font-semibold text-[24px] text-ink">4€ <span class="font-sans font-normal text-[14px] text-ink/50">/ hora</span></p>
            <span class="flex items-center gap-1 text-[13px] font-medium text-ink/70">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="#F5A623" aria-hidden="true"><path d="M6.5 0 8 4.5H13L9 7.3 10.4 12 6.5 9.2 2.6 12 4 7.3 0 4.5H5Z"/></svg>
              4.9 · 86 reservas
            </span>
          </div>

          <div class="grid grid-cols-2 gap-px bg-ink/10 border border-ink/10 rounded-lg overflow-hidden mb-3">
            <div class="bg-paper px-4 py-3">
              <label for="ficha-in" class="field-label">Entrada</label>
              <input id="ficha-in" type="date" class="field" />
            </div>
            <div class="bg-paper px-4 py-3">
              <label for="ficha-out" class="field-label">Salida</label>
              <input id="ficha-out" type="date" class="field" />
            </div>
          </div>

          <dl class="text-[14px] text-ink/65 divide-y divide-ink/8 border-y border-ink/8 mb-5">
            <div class="flex justify-between py-2.5"><dt>4€ × 6 horas</dt><dd>24,00 €</dd></div>
            <div class="flex justify-between py-2.5"><dt>Comisión de servicio</dt><dd>2,40 €</dd></div>
            <div class="flex justify-between py-3 font-semibold text-ink"><dt>Total</dt><dd>26,40 €</dd></div>
          </dl>

          <button type="button" class="btn-primary w-full rounded-full py-3.5 font-semibold text-[15px]">
            Reservar esta plaza
          </button>
          <p class="mt-3 text-center text-[12px] text-ink/40">No se te cobrará todavía · cancelación gratuita hasta 24h antes</p>
        </div>
      </div>
    </div>
  </div>
</section>
