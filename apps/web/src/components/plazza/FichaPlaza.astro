---
import { resolvePhotoUrl, type PublicParking } from '../../lib/parking';

interface Props {
  parking: PublicParking;
}

const { parking } = Astro.props;
const photos = parking.photoUrls.map(resolvePhotoUrl);
---
<section class="py-16 md:py-24 px-5 md:px-10">
  <div class="max-w-[1280px] mx-auto">
    <a href="/plazas" class="text-[13px] font-medium text-ink/50 hover:text-ink transition">← Todas las plazas</a>

    <div class="grid lg:grid-cols-12 gap-8 lg:gap-14 mt-6">
      <!-- Galería -->
      <div class="lg:col-span-7">
        {photos.length > 0 ? (
          <div class="grid grid-cols-3 grid-rows-2 gap-2.5 h-[320px] md:h-[420px]">
            <div
              class="col-span-2 row-span-2 rounded-lg bg-cover bg-center"
              style={`background-image:url(${photos[0]})`}
            ></div>
            {[photos[1], photos[2]].map((src) => (
              src
                ? <div class="rounded-lg bg-cover bg-center" style={`background-image:url(${src})`}></div>
                : <div class="plaza-ph rounded-lg" aria-hidden="true"></div>
            ))}
          </div>
        ) : (
          <div class="grid grid-cols-3 grid-rows-2 gap-2.5 h-[320px] md:h-[420px]">
            <div class="plaza-ph col-span-2 row-span-2 rounded-lg" aria-hidden="true"></div>
            <div class="plaza-ph rounded-lg" aria-hidden="true"></div>
            <div class="plaza-ph rounded-lg" aria-hidden="true"></div>
          </div>
        )}

        <div class="mt-8 flex items-start justify-between gap-6 flex-wrap">
          <div>
            <h1 class="font-plazza font-semibold text-[22px] md:text-[26px] tracking-tight text-ink mb-1.5">
              {parking.title}
            </h1>
            <p class="text-[15px] text-ink/60">{parking.address}</p>
          </div>
          <span class="flex items-center gap-1.5 rounded-full bg-signal/10 text-signal text-[13px] font-semibold px-3 py-1.5 shrink-0">
            <span class="block w-[6px] h-[6px] rounded-full bg-signal" aria-hidden="true"></span>
            Disponible
          </span>
        </div>

        {parking.description && (
          <p class="mt-5 text-[15px] leading-[1.6] text-ink/65 max-w-[560px]">
            {parking.description}
          </p>
        )}
      </div>

      <!-- Reserva -->
      <div class="lg:col-span-5">
        <div class="rounded-xl border border-ink/10 bg-white p-6 md:p-7 lg:sticky lg:top-24">
          <div class="flex items-baseline justify-between mb-6">
            <p class="font-plazza font-semibold text-[24px] text-ink">
              {parking.pricePerDay}€ <span class="font-sans font-normal text-[14px] text-ink/50">/ día</span>
            </p>
          </div>

          <a
            href="/contacto"
            class="btn-primary w-full rounded-full py-3.5 font-semibold text-[15px] block text-center"
          >
            Contactar para reservar
          </a>
          <p class="mt-3 text-center text-[12px] text-ink/40">
            La reserva y el pago se gestionan desde la app Plazza.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
