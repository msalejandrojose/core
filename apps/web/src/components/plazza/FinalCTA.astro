<section id="publicar" class="px-5 md:px-10 py-20 md:py-32 bg-asphalt-900 text-paper">
  <div class="max-w-[820px] mx-auto text-center reveal">
    <p class="font-mono text-[11px] tracking-[0.16em] uppercase text-amber mb-5">Únete a Plazza</p>
    <h2 class="font-plazza text-[clamp(30px,4.6vw,54px)] leading-[1.05] [letter-spacing:var(--tracking-tightest)] font-semibold mb-6">
      ¿Buscas plaza o tienes una libre?
    </h2>
    <p class="text-[16px] md:text-[18px] leading-[1.55] text-paper/70 mb-10 max-w-[520px] mx-auto">
      Estamos validando el interés antes de abrir la plataforma. Dinos qué necesitas y te avisamos
      en cuanto haya plazas disponibles en tu zona.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="#buscador" class="btn-primary rounded-full px-7 py-3.5 font-semibold text-[15px] w-full sm:w-auto text-center">
        Buscar una plaza
      </a>
      <a href="/contacto" class="rounded-full border border-paper/25 px-7 py-3.5 font-semibold text-[15px] text-paper hover:bg-paper/10 transition w-full sm:w-auto text-center">
        Publicar mi plaza
      </a>
    </div>
  </div>
</section>
