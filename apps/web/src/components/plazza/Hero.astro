---
---
<section id="top" class="relative pt-16 md:pt-20 pb-20 md:pb-28 px-5 md:px-10 overflow-hidden">
  <div class="max-w-[1280px] mx-auto">
    <div class="max-w-[720px] reveal">
      <div class="inline-flex items-center gap-2.5 px-3 py-1.5 mb-6 bg-asphalt-900/5 border border-asphalt-900/10 rounded-full">
        <span class="block w-[7px] h-[7px] rounded-full bg-signal pulse-dot" aria-hidden="true"></span>
        <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-asphalt-700 leading-none">
          Nuevo · parking para eventos en tu ciudad
        </span>
      </div>

      <h1 class="font-plazza text-[clamp(34px,5.2vw,58px)] leading-[1.02] [letter-spacing:var(--tracking-tightest)] font-semibold text-ink mb-5">
        Encuentra plaza.<br />
        <span class="text-amber-dark">Justo donde vas.</span>
      </h1>

      <p class="text-[17px] md:text-[18px] leading-[1.55] text-ink/65 mb-10 max-w-[520px]">
        Miles de plazas privadas cerca de estadios, conciertos y estaciones. Reserva por horas o días
        al precio de un particular, o publica tu plaza libre y gana dinero con ella.
      </p>
    </div>

    <!-- Buscador: ubicación + fechas -->
    <form
      id="buscador"
      class="reveal grid grid-cols-1 md:grid-cols-[1.4fr_1fr_1fr_auto] gap-px bg-ink/10 border border-ink/10 rounded-xl md:rounded-full overflow-hidden shadow-[0_20px_50px_-30px_rgba(20,22,26,0.4)]"
      style="transition-delay: .1s"
    >
      <div class="bg-paper px-5 md:px-6 py-3.5">
        <label for="plazza-where" class="field-label">Dónde</label>
        <input id="plazza-where" type="text" class="field" placeholder="Estadio, barrio o dirección" autocomplete="off" />
      </div>
      <div class="bg-paper px-5 md:px-6 py-3.5">
        <label for="plazza-in" class="field-label">Entrada</label>
        <input id="plazza-in" type="date" class="field" />
      </div>
      <div class="bg-paper px-5 md:px-6 py-3.5">
        <label for="plazza-out" class="field-label">Salida</label>
        <input id="plazza-out" type="date" class="field" />
      </div>
      <button
        type="submit"
        class="btn-primary flex items-center justify-center gap-2 px-7 py-3.5 md:py-0 font-semibold text-[15px]"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.6" />
          <path d="M11 11 15 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
        Buscar
      </button>
    </form>
    <p class="mt-3 text-[12px] text-ink/40 reveal" style="transition-delay: .15s">
      Prueba de concepto — la búsqueda aún no está conectada a disponibilidad real.
    </p>
  </div>
</section>
