---
const faqs = [
  { q: '¿Es necesario reservar mesa?', a: 'Lo recomendamos, sobre todo viernes, sábado y domingo. Puedes solicitar tu reserva desde esta web y te confirmamos por teléfono o email.' },
  { q: '¿Tenéis opciones vegetarianas y veganas?', a: 'Sí. La carta tiene una sección vegetariana propia, con varios platos también aptos para veganos.' },
  { q: '¿Podemos ir con niños?', a: 'Por supuesto. Tenemos trona disponible y una carta reducida pensada para los más pequeños.' },
  { q: '¿Aceptáis grupos grandes o eventos privados?', a: 'Sí, disponemos de un espacio para grupos de hasta 20 personas. Escríbenos con la fecha y seremos comensales a medida.' },
  { q: '¿Hay parking cerca?', a: 'Hay un parking público a menos de 100 metros del restaurante.' },
];
---
<section class="py-24 md:py-36 px-5 md:px-10 border-t border-charcoal/10">
  <div class="max-w-[820px] mx-auto">
    <div class="mb-14 md:mb-16 reveal">
      <p class="eyebrow mb-4">Preguntas frecuentes</p>
      <h2 class="font-brasa text-[clamp(28px,3.8vw,42px)] leading-[1.08] [letter-spacing:var(--tracking-tighter)] font-semibold">
        Lo que más nos preguntan.
      </h2>
    </div>

    <dl class="divide-y divide-charcoal/10 border-y border-charcoal/10">
      {faqs.map((f) => (
        <div class="py-7 md:py-9 grid md:grid-cols-12 gap-3 md:gap-8 reveal">
          <dt class="md:col-span-5 font-brasa text-[18px] md:text-[20px] leading-snug font-semibold [letter-spacing:var(--tracking-tighter)]">{f.q}</dt>
          <dd class="md:col-span-7 text-[16px] leading-[1.6] text-charcoal/65">{f.a}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
