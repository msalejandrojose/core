---
---
<section class="relative min-h-[100dvh] flex items-center pt-20 pb-16 px-6 md:px-12 overflow-hidden">

  <!-- Background glow blob -->
  <div
    class="absolute top-0 right-0 w-[700px] h-[700px] pointer-events-none select-none"
    aria-hidden="true"
    style="background: radial-gradient(circle at 70% 40%, rgba(102,187,106,0.10) 0%, rgba(255,193,7,0.06) 40%, transparent 70%); transform: translate(10%, -10%);"
  ></div>
  <div
    class="absolute bottom-0 left-0 w-[500px] h-[500px] pointer-events-none select-none"
    aria-hidden="true"
    style="background: radial-gradient(circle, rgba(255,143,0,0.07) 0%, transparent 65%); transform: translate(-20%, 20%);"
  ></div>

  <div class="relative z-10 max-w-[1340px] mx-auto w-full grid md:grid-cols-2 gap-12 md:gap-8 items-center">

    <!-- ── LEFT: copy ──────────────────────────────── -->
    <div>

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-fresh/15 border border-fresh/30 mb-8 reveal">
        <span class="w-2 h-2 rounded-full bg-fresh shrink-0" aria-hidden="true"></span>
        <span class="font-display font-semibold text-[12px] text-leaf tracking-wide uppercase">Recogida esta mañana</span>
      </div>

      <!-- H1 -->
      <h1
        class="font-display font-extrabold leading-[1.05] tracking-tight text-ink reveal reveal-delay-1"
        style="font-size: clamp(48px, 7vw, 88px);"
      >
        Del huerto<br/>
        <span style="color: var(--color-citrus);">a tu mesa.</span>
      </h1>

      <!-- Subheadline -->
      <p class="mt-6 font-body text-[17px] md:text-[19px] leading-[1.65] text-ink-soft max-w-[480px] reveal reveal-delay-2">
        Fruta fresca recogida hoy y entregada en horas. Sin cámaras frigoríficas, sin almacenes, sin esperas.
      </p>

      <!-- CTAs -->
      <div class="mt-9 flex flex-wrap items-center gap-4 reveal reveal-delay-3">
        <a href="#pedir" class="btn-citrus">Pedir ahora</a>
        <a href="#frutas" class="btn-ghost">Ver frutas</a>
      </div>

      <!-- Quick trust line -->
      <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-2 reveal reveal-delay-4">
        {['100% natural', 'Recogida hoy', 'Entrega en 24h', 'Sin intermediarios'].map(label => (
          <span class="inline-flex items-center gap-1.5 font-body text-[13px] text-dust">
            <span class="w-1.5 h-1.5 rounded-full bg-fresh shrink-0" aria-hidden="true"></span>
            {label}
          </span>
        ))}
      </div>

    </div>

    <!-- ── RIGHT: fruta animada ────────────────────── -->
    <div class="relative flex items-center justify-center min-h-[420px] md:min-h-[580px]">

      <!-- Glow behind fruit -->
      <div
        class="absolute inset-[15%] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(255,193,7,0.18) 0%, rgba(102,187,106,0.10) 50%, transparent 75%); filter: blur(32px);"
        aria-hidden="true"
      ></div>

      <!-- Fruta principal -->
      <div class="relative z-10 fruit-float" style="width: min(460px, 90vw);">
        <img
          src="https://picsum.photos/seed/orchard-citrus-orange-slice-fresh-water/560/560"
          alt="Naranjas recién cortadas con gotas de agua"
          width="560"
          height="560"
          class="w-full rounded-3xl object-cover"
          style="aspect-ratio: 1/1; box-shadow: 0 24px 64px rgba(46,125,50,0.18), 0 8px 24px rgba(255,143,0,0.12);"
          fetchpriority="high"
          decoding="async"
        />
      </div>

      <!-- Fruta secundaria (floating offset) -->
      <div
        class="absolute bottom-[4%] right-[2%] z-20 fruit-float-slow"
        style="width: min(160px, 28vw); animation-delay: 1.4s;"
      >
        <img
          src="https://picsum.photos/seed/orchard-strawberry-fresh-dewy-close/200/200"
          alt="Fresas frescas con rocío"
          width="200"
          height="200"
          class="w-full rounded-2xl object-cover"
          style="box-shadow: 0 12px 32px rgba(229,57,53,0.20);"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Decorative water drops -->
      <div class="absolute top-[10%] right-[10%] w-4 h-4 rounded-full bg-citrus/40 drop-breathe pointer-events-none" style="filter:blur(1px); animation-delay:0s;"    aria-hidden="true"></div>
      <div class="absolute top-[35%] left-[5%]  w-3 h-3 rounded-full bg-fresh/50  drop-breathe pointer-events-none" style="filter:blur(1px); animation-delay:1.1s;"   aria-hidden="true"></div>
      <div class="absolute top-[65%] right-[28%] w-5 h-5 rounded-full bg-mango/35 drop-breathe pointer-events-none" style="filter:blur(2px); animation-delay:0.7s;"   aria-hidden="true"></div>
      <div class="absolute top-[18%] left-[18%] w-2.5 h-2.5 rounded-full bg-berry/30 drop-breathe pointer-events-none" style="filter:blur(1px); animation-delay:1.8s;" aria-hidden="true"></div>

    </div>

  </div>
</section>
