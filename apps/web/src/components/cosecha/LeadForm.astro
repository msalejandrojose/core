---
interface Props {
  idSuffix?:    string;
  showName?:    boolean;
  showCity?:    boolean;
  buttonLabel?: string;
  variant?:     'light' | 'dark';
}

const {
  idSuffix    = '',
  showName    = false,
  showCity    = false,
  buttonLabel = 'Quiero ser de los primeros',
  variant     = 'light',
} = Astro.props;

const isDark     = variant === 'dark';
const labelClass = `block font-mono text-[10px] font-medium uppercase tracking-[0.14em] mb-2 ${isDark ? 'text-warm-white/40' : 'text-brown/50'}`;
const fieldClass = `field${isDark ? ' field-light' : ''}`;
---
<form class="space-y-5" action="#" method="post" novalidate>

  {showName && (
    <div>
      <label for={`nombre${idSuffix}`} class={labelClass}>Nombre</label>
      <input
        type="text"
        id={`nombre${idSuffix}`}
        name="nombre"
        class={fieldClass}
        placeholder="Tu nombre"
        autocomplete="given-name"
      />
    </div>
  )}

  <div>
    <label for={`email${idSuffix}`} class={labelClass}>Correo electrónico</label>
    <input
      type="email"
      id={`email${idSuffix}`}
      name="email"
      class={fieldClass}
      placeholder="tu@correo.com"
      required
      autocomplete="email"
    />
  </div>

  {showCity && (
    <div>
      <label for={`ciudad${idSuffix}`} class={labelClass}>
        Ciudad
        <span class={`ml-1 normal-case tracking-normal font-normal ${isDark ? 'text-warm-white/25' : 'text-brown/30'}`}>(opcional)</span>
      </label>
      <input
        type="text"
        id={`ciudad${idSuffix}`}
        name="ciudad"
        class={fieldClass}
        placeholder="Madrid"
        autocomplete="address-level2"
      />
    </div>
  )}

  <button type="submit" class={isDark ? 'btn-ghost-light w-full mt-2' : 'btn-fruit w-full mt-2'}>
    {buttonLabel}
  </button>

  <p class={`font-body text-[12px] text-center leading-relaxed ${isDark ? 'text-warm-white/28' : 'text-brown/40'}`}>
    Sin spam. Solo te avisamos cuando abramos.
  </p>

</form>
