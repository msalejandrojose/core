---
const year = new Date().getFullYear();
---
<footer class="px-6 md:px-12 py-10 border-t border-paper-dark bg-warm-white">
  <div class="max-w-[1340px] mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-6">

    <p class="font-display text-[17px] font-light italic tracking-[-0.01em] text-charcoal">
      Cosecha
    </p>

    <p class="font-body text-[12px] text-brown-faint text-center md:text-center order-last md:order-none">
      Del árbol a tu mesa, sin rodeos.
    </p>

    <p class="font-mono text-[11px] text-brown-faint/60 tracking-[0.06em]">
      © {year}
    </p>

  </div>
</footer>
