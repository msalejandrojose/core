---
import LeadForm from './LeadForm.astro';
---
<section id="top" class="relative min-h-[100dvh] overflow-hidden">

  <div id="cosecha-sentinel" class="absolute top-16 left-0 w-px h-px pointer-events-none" aria-hidden="true"></div>

  <!-- Fotografía de fondo -->
  <img
    src="https://picsum.photos/seed/cosecha-hands-oranges-golden-hour/1400/900"
    alt="Manos sosteniendo naranjas recién recolectadas con luz dorada de atardecer"
    width="1400"
    height="900"
    class="absolute inset-0 w-full h-full object-cover object-center"
    fetchpriority="high"
    loading="eager"
  />

  <!-- Gradiente: transparente arriba → oscuro abajo -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to bottom, rgba(28,28,28,0) 0%, rgba(28,28,28,0.08) 30%, rgba(28,28,28,0.55) 58%, rgba(28,28,28,0.90) 100%)"
    aria-hidden="true"
  ></div>

  <!-- Contenido: parte inferior izquierda -->
  <div class="relative z-10 flex flex-col justify-end min-h-[100dvh] max-w-[1340px] mx-auto px-6 md:px-12 pb-14 md:pb-20 pt-24">
    <div class="grid md:grid-cols-12 gap-8 items-end">

      <!-- Titular (7 columnas) -->
      <div class="md:col-span-7 reveal">
        <h1 class="font-display text-[clamp(44px,6vw,88px)] font-light italic leading-[0.98] tracking-[-0.03em] text-warm-white mb-5 md:mb-6">
          La fruta que<br />
          <em class="not-italic font-semibold">aún sabe</em><br />
          a fruta.
        </h1>

        <p class="font-body text-[16px] md:text-[17px] leading-[1.65] text-warm-white/65 max-w-[440px]">
          Seleccionamos directamente con agricultores para que la fruta llegue recién recolectada, con todo su sabor.
        </p>
      </div>

      <!-- Formulario (5 columnas) -->
      <div class="md:col-span-5 reveal reveal-delay-2">
        <div class="bg-charcoal/25 backdrop-blur-sm rounded-sm p-6 md:p-8 border border-warm-white/10">
          <p class="font-display text-[15px] font-light italic text-warm-white/80 mb-5">
            Avísame cuando abráis
          </p>
          <LeadForm idSuffix="-hero" variant="dark" buttonLabel="Quiero ser de los primeros" />
        </div>
      </div>

    </div>
  </div>

</section>
