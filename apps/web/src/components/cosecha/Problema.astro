---
---
<section class="py-24 md:py-44 px-6 md:px-12">
  <div class="max-w-[1340px] mx-auto">

    <!-- Titular editorial centrado -->
    <div class="max-w-[720px] mx-auto text-center mb-16 md:mb-24 reveal">
      <h2 class="font-display text-[clamp(30px,4.5vw,62px)] font-light italic leading-[1.05] tracking-[-0.025em] text-charcoal mb-6">
        ¿Por qué la fruta del supermercado<br />
        ya no sabe como antes?
      </h2>
      <p class="font-body text-[16px] md:text-[17px] leading-[1.7] text-brown max-w-[520px] mx-auto">
        No es nostalgia. Es química. La fruta se recoge verde, viaja días en camiones, pasa semanas en cámaras frigoríficas y llega a tu casa sin haber madurado en el árbol.
      </p>
    </div>

    <!-- Contraste visual: supermarket vs campo -->
    <div class="grid md:grid-cols-2 gap-4 md:gap-6">

      <!-- Supermercado: tratamiento desaturado -->
      <div class="relative overflow-hidden rounded-sm reveal">
        <div class="img-ph aspect-[4/3] md:aspect-[3/2]" aria-hidden="true"></div>
        <div class="absolute inset-0 bg-warm-white/20 mix-blend-saturation" aria-hidden="true"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5 md:p-7">
          <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-brown/60 mb-1">Supermercado</p>
          <p class="font-display text-[16px] md:text-[18px] font-light italic text-charcoal/75">
            Recogida verde. Días de almacén. Sin sabor.
          </p>
        </div>
      </div>

      <!-- Campo: vibrant -->
      <div class="relative overflow-hidden rounded-sm reveal reveal-delay-2">
        <img
          src="https://picsum.photos/seed/cosecha-peaches-sunlit-crate/700/500"
          alt="Caja de melocotones recién recolectados con luz de sol directa"
          width="700"
          height="500"
          class="w-full aspect-[4/3] md:aspect-[3/2] object-cover"
          loading="lazy"
        />
        <div class="absolute bottom-0 left-0 right-0 p-5 md:p-7" style="background: linear-gradient(to top, rgba(28,28,28,0.65) 0%, transparent 100%)">
          <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-warm-white/55 mb-1">Del campo</p>
          <p class="font-display text-[16px] md:text-[18px] font-light italic text-warm-white">
            Recogida madura. Enviada hoy. Con todo su sabor.
          </p>
        </div>
      </div>

    </div>

  </div>
</section>
