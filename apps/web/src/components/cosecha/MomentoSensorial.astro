---
---
<section class="relative min-h-[80vh] md:min-h-[92vh] overflow-hidden flex items-end">

  <!-- Fotografía macro protagonista -->
  <img
    src="https://picsum.photos/seed/cosecha-macro-orange-drops-texture/1400/800"
    alt="Textura de fruta madura con luz natural, gotas de agua en la piel"
    width="1400"
    height="800"
    class="absolute inset-0 w-full h-full object-cover object-center"
    loading="lazy"
  />

  <!-- Gradiente sutil: solo oscurece la zona del texto -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to bottom, rgba(28,28,28,0) 20%, rgba(28,28,28,0.72) 100%)"
    aria-hidden="true"
  ></div>

  <!-- Texto poético — sin elementos UI que compitan -->
  <div class="relative z-10 w-full max-w-[1340px] mx-auto px-6 md:px-12 pb-16 md:pb-24">
    <div class="max-w-[680px] reveal">
      <p class="font-display text-[clamp(28px,4.2vw,58px)] font-light italic leading-[1.15] tracking-[-0.02em] text-warm-white">
        Hay un momento exacto<br />
        en que la fruta alcanza<br />
        su punto perfecto.
      </p>
      <p class="font-display text-[clamp(22px,3vw,40px)] font-light italic leading-[1.2] tracking-[-0.02em] text-warm-white/55 mt-5 reveal reveal-delay-2">
        Recién recolectada.<br />
        Todavía cálida del sol.
      </p>
    </div>
  </div>

</section>
