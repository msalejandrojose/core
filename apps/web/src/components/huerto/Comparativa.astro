---
const superItems = [
  'Varios intermediarios entre origen y destino',
  'Fruta almacenada durante días',
  'Recolectada antes de su punto óptimo',
  'Sabor y aroma reducidos',
  'Origen poco claro',
];

const nuestroItems = [
  'Directo del agricultor',
  'Recién recolectada',
  'En su punto óptimo de maduración',
  'Sabor y aroma intactos',
  'Trazabilidad completa',
];
---
<section class="py-24 md:py-40 px-5 md:px-10 bg-stone-50">
  <div class="max-w-[1280px] mx-auto">

    <div class="mb-14 md:mb-20 reveal">
      <h2 class="font-huerto text-[clamp(26px,3.6vw,48px)] font-bold leading-[1.05] tracking-[-0.03em] text-ink">
        ¿Por qué somos diferentes?
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-4 md:gap-5 max-w-[860px]">

      <!-- Supermercado -->
      <div class="bg-paper border border-stone-200 rounded-xl p-8 md:p-10 reveal">
        <div class="flex items-center gap-3 mb-8">
          <span class="w-2 h-2 rounded-full bg-stone-300 shrink-0" aria-hidden="true"></span>
          <p class="font-huerto-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-stone-400">
            Supermercado
          </p>
        </div>
        <ul class="space-y-4" role="list">
          {superItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="mt-0.5 shrink-0">
                <path d="M3.5 3.5l7 7M10.5 3.5l-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-stone-300"/>
              </svg>
              <span class="text-[14px] text-ink/35 line-through decoration-stone-300/60">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Nosotros -->
      <div class="bg-forest border border-forest rounded-xl p-8 md:p-10 reveal reveal-delay-2">
        <div class="flex items-center gap-3 mb-8">
          <span class="w-2 h-2 rounded-full bg-olive-light shrink-0" aria-hidden="true"></span>
          <p class="font-huerto-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-paper/40">
            Nosotros
          </p>
        </div>
        <ul class="space-y-4" role="list">
          {nuestroItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="mt-0.5 shrink-0">
                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-olive-light"/>
              </svg>
              <span class="text-[14px] text-paper/80 font-medium">{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

  </div>
</section>
