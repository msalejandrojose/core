---
import LeadForm from './LeadForm.astro';
---
<section id="top" class="relative grid md:grid-cols-12 min-h-[100dvh]">

  <div id="scroll-sentinel" class="absolute top-20 left-0 w-px h-px pointer-events-none" aria-hidden="true"></div>

  <!-- Imagen izquierda — 7 columnas -->
  <div class="md:col-span-7 relative min-h-[55vw] md:min-h-[100dvh] order-1">
    <img
      src="https://picsum.photos/seed/huerto-orchard-golden-morning/900/1200"
      alt="Fruta recién recolectada del huerto al amanecer, con luz dorada natural"
      width="900"
      height="1200"
      class="w-full h-full object-cover"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-paper/30 hidden md:block" aria-hidden="true"></div>
  </div>

  <!-- Texto derecha — 5 columnas -->
  <div class="md:col-span-5 flex flex-col justify-center px-6 md:px-10 lg:px-14 py-20 md:py-28 order-2">

    <h1 class="font-huerto text-[clamp(36px,4.2vw,58px)] font-bold leading-[1.02] tracking-[-0.03em] text-ink mb-6 md:mb-7">
      La fruta del huerto<br />directamente<br />
      <span class="text-olive">a tu mesa.</span>
    </h1>

    <p class="text-[16px] md:text-[17px] leading-[1.65] text-ink/60 mb-9 max-w-[400px]">
      Estamos creando una nueva forma de disfrutar fruta fresca: recién recolectada, con más sabor y a un precio justo, directamente del agricultor.
    </p>

    <LeadForm idSuffix="-hero" />
  </div>

</section>
