---
const year = new Date().getFullYear();
---
<footer class="py-12 md:py-16 px-5 md:px-10 border-t border-stone-200">
  <div class="max-w-[1280px] mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

    <!-- Logo + tagline -->
    <div>
      <div class="flex items-center gap-2.5 mb-2">
        <svg width="18" height="18" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M11 3C7.5 3 5 5.8 5 9.2c0 2.6 1.4 4.8 3.5 6.4V9h1.5v7.5c.3.05.65.08 1 .08s.7-.03 1-.08V9H13v6.6C15.1 14 16.5 11.8 16.5 9.2 16.5 5.8 14 3 11 3z" fill="currentColor" class="text-olive"/>
        </svg>
        <span class="text-[14px] font-bold text-ink tracking-[-0.02em]">Huerto</span>
      </div>
      <p class="text-[13px] text-ink/40">Fruta del agricultor directamente a tu mesa.</p>
    </div>

    <!-- Links -->
    <nav aria-label="Pie de página">
      <ul class="flex flex-wrap gap-6" role="list">
        <li>
          <a href="#" class="text-[13px] text-ink/45 hover:text-ink transition-colors duration-150">
            Aviso legal
          </a>
        </li>
        <li>
          <a href="#" class="text-[13px] text-ink/45 hover:text-ink transition-colors duration-150">
            Política de privacidad
          </a>
        </li>
        <li>
          <a href="#" class="text-[13px] text-ink/45 hover:text-ink transition-colors duration-150">
            Política de cookies
          </a>
        </li>
        <li>
          <a href="mailto:hola@huerto.es" class="text-[13px] text-ink/45 hover:text-ink transition-colors duration-150">
            Contacto
          </a>
        </li>
      </ul>
    </nav>

    <!-- Copyright -->
    <p class="font-huerto-mono text-[11px] text-ink/30 tracking-wide shrink-0">
      &copy; {year} Huerto
    </p>

  </div>
</footer>
