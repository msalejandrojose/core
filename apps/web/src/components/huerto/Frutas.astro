---
const fruits = [
  { name: 'Naranjas',     season: 'Nov - Mar',     seed: 'huerto-oranges-bright' },
  { name: 'Mandarinas',   season: 'Oct - Feb',     seed: 'huerto-mandarins-harvest' },
  { name: 'Limones',      season: 'Todo el año',   seed: 'huerto-lemons-tree' },
  { name: 'Melocotones',  season: 'Jun - Sep',     seed: 'huerto-peaches-golden' },
  { name: 'Paraguayos',   season: 'Jun - Ago',     seed: 'huerto-flatpeach-summer' },
  { name: 'Nectarinas',   season: 'Jun - Sep',     seed: 'huerto-nectarines-red' },
  { name: 'Albaricoques', season: 'May - Jul',     seed: 'huerto-apricots-orange' },
  { name: 'Caquis',       season: 'Oct - Dic',     seed: 'huerto-persimmon-autumn' },
  { name: 'Aguacates',    season: 'Oct - Mar',     seed: 'huerto-avocado-green' },
  { name: 'Tomates',      season: 'Jun - Oct',     seed: 'huerto-tomatoes-ripe' },
] as const;
---
<section class="py-24 md:py-40 px-5 md:px-10">
  <div class="max-w-[1280px] mx-auto">

    <div class="mb-12 md:mb-16 reveal">
      <h2 class="font-huerto text-[clamp(26px,3.6vw,48px)] font-bold leading-[1.05] tracking-[-0.03em] text-ink mb-3">
        Muy pronto podrás disfrutar de
      </h2>
      <p class="text-[15px] text-ink/45">Fruta de temporada, recogida en su mejor momento.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 md:gap-4">
      {fruits.map((fruit, i) => (
        <article
          class={`group border border-stone-200 rounded-xl overflow-hidden card-lift reveal ${
            i >= 5 ? 'reveal-delay-2' : i >= 1 ? 'reveal-delay-1' : ''
          }`}
        >
          <div class="aspect-square overflow-hidden bg-stone-50">
            <img
              src={`https://picsum.photos/seed/${fruit.seed}/300/300`}
              alt={`${fruit.name} de temporada recién recolectados`}
              width="300"
              height="300"
              class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-3 md:p-4">
            <p class="font-huerto font-semibold text-[14px] text-ink mb-0.5">{fruit.name}</p>
            <p class="font-huerto-mono text-[11px] text-stone-400 tracking-wide">{fruit.season}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
