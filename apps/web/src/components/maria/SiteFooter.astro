---
<footer id="contacto" class="bg-leaf-deep text-cream pt-20 md:pt-28 pb-10">
  <div class="wrap">

    <div class="grid gap-12 md:gap-8 md:grid-cols-12">

      <!-- Marca + manifiesto + redes -->
      <div class="md:col-span-5 lg:col-span-4">
        <a href="#inicio" class="inline-flex items-center gap-2.5" aria-label="María — inicio">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 21c0-5 0-8 0-8m0 0c-2.5 0-6-1.6-6-6 0-.9.2-1.7.5-2.4C8 5.4 10.2 6.6 12 9c1.8-2.4 4-3.6 5.5-4.4.3.7.5 1.5.5 2.4 0 4.4-3.5 6-6 6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-hand text-[32px] leading-none translate-y-[1px]">María</span>
        </a>
        <p class="mt-5 max-w-[320px] text-cream/65 text-[15px] leading-[1.6]">
          La fruta que aún sabe a fruta. Una empresa familiar que cuida cada árbol
          hasta su punto exacto de maduración.
        </p>

        <div class="mt-7 flex items-center gap-3">
          {social.map((s) => (
            <a
              href={s.href}
              class="grid place-items-center size-10 rounded-full border border-cream/18 text-cream/80 hover:text-cream hover:border-cream/45 transition-colors"
              aria-label={s.label}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={s.d} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Explora -->
      <nav class="md:col-span-3 lg:col-span-3 lg:col-start-7" aria-label="Explora">
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-cream/45">Explora</p>
        <ul class="mt-5 space-y-3" role="list">
          {explora.map((l) => (
            <li><a href={l.href} class="foot-link text-[15px]">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Contacto + dirección -->
      <div class="md:col-span-4 lg:col-span-3">
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-cream/45">Contacto</p>
        <ul class="mt-5 space-y-3 text-[15px]" role="list">
          <li><a href="mailto:hola@fruta-maria.es" class="foot-link">hola@fruta-maria.es</a></li>
          <li><a href="tel:+34960000000" class="foot-link">+34 960 000 000</a></li>
        </ul>
        <address class="mt-6 not-italic text-cream/60 text-[14.5px] leading-[1.6]">
          Camí de l'Horta, 12<br />
          Vega Baja del Segura<br />
          03360 Alicante, España
        </address>
      </div>
    </div>

    <!-- Línea inferior -->
    <div class="rule-light mt-16 md:mt-20"></div>
    <div class="pt-6 flex flex-col-reverse md:flex-row items-start md:items-center justify-between gap-5">
      <p class="text-[12.5px] text-cream/50">
        © {year} María · Cultivado con cariño en el Mediterráneo.
      </p>
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-2" role="list">
        {legal.map((l) => (
          <li><a href={l.href} class="foot-link text-[12.5px]">{l.label}</a></li>
        ))}
      </ul>
    </div>

  </div>
</footer>
