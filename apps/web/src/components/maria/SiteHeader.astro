---
const nav = [
  { label: 'Filosofía', href: '#filosofia' },
  { label: 'La fruta',  href: '#fruta' },
  { label: 'Historia',  href: '#historia' },
];
---
<header id="maria-header" class="fixed top-0 inset-x-0 z-50">
  <div class="wrap flex items-center justify-between gap-8 py-5">

    <!-- Marca -->
    <a href="#inicio" class="brand group inline-flex items-center gap-2.5 shrink-0" aria-label="María — inicio">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:-rotate-6">
        <path d="M12 21c0-5 0-8 0-8m0 0c-2.5 0-6-1.6-6-6 0-.9.2-1.7.5-2.4C8 5.4 10.2 6.6 12 9c1.8-2.4 4-3.6 5.5-4.4.3.7.5 1.5.5 2.4 0 4.4-3.5 6-6 6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="font-hand text-[30px] leading-none translate-y-[1px]">María</span>
    </a>

    <!-- Navegación -->
    <nav class="hidden md:flex items-center gap-9" aria-label="Principal">
      {nav.map((item) => (
        <a href={item.href} class="nav-link text-[14px] font-medium tracking-[0.01em]">
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <a href="#contacto" class="btn btn-line-light text-[13.5px] px-5 py-2.5 hidden sm:inline-flex">
      Escríbenos
    </a>
  </div>
</header>
