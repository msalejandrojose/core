---
import Wordmark from './Wordmark.astro';
---
<footer class="bg-forest text-cream/65 px-5 md:px-10 py-12 border-t border-cream/10">
  <div class="max-w-[1280px] mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">
    <div class="flex items-center gap-2.5">
      <Wordmark variant="light" />
      <span class="font-mono text-[11px] tracking-[0.14em] uppercase text-cream/40 ml-2">Albacete</span>
    </div>
    <nav class="flex flex-wrap gap-x-6 gap-y-2 text-[13px]" aria-label="Contacto">
      <a href="mailto:hola@sazon.es" class="hover:text-cream transition">hola@sazon.es</a>
      <a href="tel:+34000000000" class="hover:text-cream transition">+34 000 000 000</a>
      <a href="https://instagram.com" class="hover:text-cream transition" rel="me noopener">Instagram</a>
    </nav>
    <nav class="flex flex-wrap gap-x-5 gap-y-2 text-[12px] text-cream/45" aria-label="Legal">
      <a href="/aviso-legal" class="hover:text-cream transition">Aviso legal</a>
      <a href="/privacidad" class="hover:text-cream transition">Privacidad</a>
      <a href="/cookies" class="hover:text-cream transition">Cookies</a>
    </nav>
  </div>
</footer>
