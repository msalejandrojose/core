---
import { Image } from 'astro:assets';
import LeadForm from './LeadForm.astro';
import IconLeaf from './icons/IconLeaf.astro';
import olive from '../../assets/land/olive-grove.jpeg';

interface Props {
  seasonal?: string[];
}

const { seasonal = ['cerezas', 'paraguayo', 'melocotón'] } = Astro.props;
const seasonalText = seasonal.join(' · ');
---
<section id="top" class="relative pt-24 md:pt-28 pb-12 md:pb-20 px-5 md:px-10 overflow-hidden">
  <div class="max-w-[1280px] mx-auto grid md:grid-cols-12 gap-8 md:gap-14 lg:gap-20 items-center min-h-[86vh]">

    <!-- Escena 3D: foto de origen que inclina con el puntero y hace parallax al scroll -->
    <div class="md:col-span-7 order-1 reveal scene">
      <div data-tilt data-tilt-max="5" class="relative">
        <div class="parallax relative rounded-xl overflow-hidden depth-1 shadow-[0_40px_80px_-40px_rgba(31,37,25,0.55)]">
          <Image
            src={olive}
            alt="Olivar de la comarca de Albacete visto desde el aire, en hileras"
            widths={[560, 840, 1200]}
            sizes="(min-width: 768px) 58vw, 100vw"
            class="parallax-media w-full aspect-[4/5] md:aspect-[5/6] object-cover"
            loading="eager"
            fetchpriority="high"
          />
          <div class="glare"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-forest/25 via-transparent to-transparent" aria-hidden="true"></div>
        </div>

        <!-- Chip de vidrio flotante, a mayor profundidad para el efecto 3D -->
        <div class="glass depth-3 absolute left-4 bottom-4 md:left-6 md:bottom-6 rounded-full pl-3 pr-4 py-2 flex items-center gap-2.5">
          <span class="text-olive-600"><IconLeaf /></span>
          <span class="font-mono text-[10px] md:text-[11px] uppercase tracking-[0.14em] text-ink/80 leading-none">
            Elegida a mano · Albacete
          </span>
        </div>
      </div>
    </div>

    <div class="md:col-span-5 order-2 reveal" style="transition-delay: .12s">
      <div class="inline-flex items-center gap-2.5 px-3 py-1.5 mb-6 md:mb-8 bg-white/60 backdrop-blur border border-olive-500/15 rounded-full">
        <span class="block w-[7px] h-[7px] rounded-full bg-olive-500 pulse-dot" aria-hidden="true"></span>
        <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-olive-700 leading-none">
          Esta semana · {seasonalText}
        </span>
      </div>

      <h1 class="font-sazon text-[clamp(34px,5.4vw,62px)] leading-[1.03] [letter-spacing:var(--tracking-tightest)] font-medium text-ink mb-5 md:mb-6">
        La mejor fruta<br />de temporada,<br />
        <em class="[font-family:var(--font-serif)] italic font-medium [font-optical-sizing:auto] tracking-normal text-olive-600 inline-block leading-[1.12] pb-[0.08em]">elegida por nosotros</em><br />y entregada en tu casa.
      </h1>

      <p class="text-[17px] md:text-[18px] leading-[1.55] text-ink/70 mb-7 md:mb-8 max-w-[440px]">
        Olvídate de buscar fruta buena en distintos supermercados. Seleccionamos personalmente la mejor fruta de temporada y te la llevamos a casa en Albacete.
      </p>

      <LeadForm idSuffix="-hero" />
    </div>
  </div>
</section>
