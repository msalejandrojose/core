---
import LeadForm from './LeadForm.astro';

interface Props {
  seasonal?: string[];
  heroImage?: string;
  heroAlt?: string;
}

const {
  seasonal = ['cerezas', 'paraguayo', 'melocotón'],
  heroImage,
  heroAlt = 'Caja recién preparada con fruta de temporada',
} = Astro.props;

const seasonalText = seasonal.join(' · ');
---

<!-- ── El Campo: Huerta ─────────────────────────────────────── -->
<section
  id="top"
  class="relative pt-20 md:pt-24 pb-12 md:pb-20 px-5 md:px-10"
>
  <!-- Sutil tono verde huerta de fondo -->
  <div class="absolute inset-0 pointer-events-none"
       style="background: radial-gradient(ellipse 80% 60% at 65% 50%, color-mix(in srgb, var(--color-olive-100) 35%, transparent), transparent)"
       aria-hidden="true">
  </div>

  <div class="relative max-w-[1280px] mx-auto grid md:grid-cols-12 gap-8 md:gap-14 lg:gap-20 items-center min-h-[88dvh] md:min-h-[88dvh]">

    <!-- ── Imagen izquierda ──────────────────────────────────── -->
    <div class="md:col-span-7 reveal order-2 md:order-1">
      {heroImage ? (
        <img
          src={heroImage}
          alt={heroAlt}
          width="1200"
          height="1440"
          class="w-full aspect-[4/5] md:aspect-[5/6] object-cover rounded-sm"
          fetchpriority="high"
        />
      ) : (
        <div
          class="img-ph aspect-[4/5] md:aspect-[5/6] rounded-sm w-full float-gentle"
          aria-hidden="true"
        ></div>
      )}
    </div>

    <!-- ── Copy + formulario derecha ────────────────────────── -->
    <div class="md:col-span-5 reveal order-1 md:order-2" style="transition-delay: .1s">

      <!-- Pill de temporada -->
      <div class="inline-flex items-center gap-2.5 px-3 py-1.5 mb-6 md:mb-8 bg-white/60 backdrop-blur border border-olive-500/15 rounded-full">
        <span
          class="block w-[7px] h-[7px] rounded-full bg-olive-500 pulse-dot"
          aria-hidden="true"
        ></span>
        <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-olive-700 leading-none">
          Esta semana · {seasonalText}
        </span>
      </div>

      <!-- H1 con acento animado -->
      <h1 class="font-sazon text-[clamp(34px,5.4vw,62px)] leading-[1.02] [letter-spacing:var(--tracking-tightest)] font-medium text-ink mb-5 md:mb-6">
        La mejor fruta<br />de temporada,<br />
        <span class="fruit-gradient-text">elegida por nosotros</span><br />
        y entregada en tu casa.
      </h1>

      <p class="text-[17px] md:text-[18px] leading-[1.55] text-ink/70 mb-7 md:mb-8 max-w-[440px]">
        Olvídate de buscar fruta buena en distintos supermercados. Seleccionamos personalmente la mejor fruta de temporada y te la llevamos a casa en Albacete.
      </p>

      <LeadForm idSuffix="-hero" />
    </div>
  </div>

  <!-- Label de campo en esquina inferior derecha -->
  <div class="absolute bottom-6 right-5 md:right-10 flex items-center gap-2.5" aria-hidden="true">
    <div class="hairline w-8 opacity-40"></div>
    <span class="campo-label text-olive-600">Huerta · Albacete</span>
  </div>
</section>
