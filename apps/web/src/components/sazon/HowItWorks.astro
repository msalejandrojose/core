---
/*
 * HowItWorks — "El Secano"
 * Campo de secano: cálido, seco, la luz del sol hace el trabajo.
 * Tono ámbar muy suave en el fondo, líneas y números en caliente.
 */
const steps = [
  {
    n: '01',
    title: 'Tú haces la solicitud',
    body: 'Nos dices que te interesa el servicio y en qué zona estás. Sin elegir variedades ni cantidades.',
  },
  {
    n: '02',
    title: 'Nosotros seleccionamos',
    body: 'Buscamos personalmente la mejor fruta de temporada. La que tiene punto, la que está en su mejor momento.',
  },
  {
    n: '03',
    title: 'La recibes en casa',
    body: 'Cuando lancemos el servicio podrás recibir fruta fresca sin salir de casa.',
  },
];
---

<!-- ── El Campo: Secano ────────────────────────────────────── -->
<section
  class="relative py-24 md:py-36 px-5 md:px-10 border-t border-mist-dark/50 overflow-hidden"
>
  <!-- Fondo cálido ámbar-secano muy sutil -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 90% 70% at 20% 80%, color-mix(in srgb, var(--color-sun) 20%, transparent), transparent)"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-[1280px] mx-auto">

    <div class="max-w-[640px] mb-14 md:mb-20 reveal">
      <p class="eyebrow mb-4">Cómo funciona</p>
      <h2 class="font-sazon text-[clamp(28px,3.8vw,46px)] leading-[1.08] [letter-spacing:var(--tracking-tighter)] font-medium">
        Sin app, sin catálogo,<br />sin elegir entre 40 variedades.
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-12 md:gap-10">
      {steps.map((s, i) => (
        <div class="reveal" style={`transition-delay: ${i * 0.12}s`}>
          <!-- Número + línea con acento ámbar -->
          <div class="flex items-baseline gap-3 mb-5">
            <span class="font-mono text-[11px] tracking-[0.16em] text-olive-600">{s.n}</span>
            <div class="flex-1" style="height:1px; background: linear-gradient(90deg, var(--color-mango), var(--color-mist-dark) 60%);"></div>
          </div>
          <h3 class="font-sazon text-[22px] md:text-[24px] leading-tight font-medium [letter-spacing:var(--tracking-tighter)] mb-3">
            {s.title}
          </h3>
          <p class="text-[16px] leading-[1.55] text-ink/65">{s.body}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Label campo -->
  <div class="absolute bottom-6 right-5 md:right-10 flex items-center gap-2.5" aria-hidden="true">
    <div class="hairline w-8 opacity-35"></div>
    <span class="campo-label text-olive-600">Secano</span>
  </div>
</section>
