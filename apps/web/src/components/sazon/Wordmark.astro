---
interface Props {
  variant?: 'dark' | 'light';
}
const { variant = 'dark' } = Astro.props;
const color = variant === 'light' ? '#FAF6EC' : '#4A5530';
const textClass = variant === 'light' ? 'text-cream' : 'text-ink';
---
<span class="inline-flex items-center gap-2.5">
  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke={color} stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
    <path d="M3 15 C 7 11, 11 7, 15 3" />
    <ellipse cx="6.6" cy="11.4" rx="1.4" ry="2.4" transform="rotate(-42 6.6 11.4)" fill={color} stroke="none" />
    <ellipse cx="10.6" cy="7.4" rx="1.4" ry="2.4" transform="rotate(-42 10.6 7.4)" fill={color} stroke="none" />
    <ellipse cx="14.2" cy="3.8" rx="0.9" ry="1.5" transform="rotate(-42 14.2 3.8)" fill={color} stroke="none" />
  </svg>
  <span class={`font-sazon font-medium text-[15px] tracking-tight ${textClass}`}>Sazón</span>
</span>
