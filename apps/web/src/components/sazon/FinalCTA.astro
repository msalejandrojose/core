---
/*
 * FinalCTA — "La Bodega"
 * Cosecha terminada, almacén, lo mejor de la temporada conservado.
 * Fondo forest (verde oscuro) — sección de cierre.
 */
import LeadForm from './LeadForm.astro';
---

<!-- ── El Campo: La Bodega ────────────────────────────────── -->
<section
  id="contacto"
  class="relative px-5 md:px-10 py-24 md:py-36 bg-forest text-cream overflow-hidden"
>
  <!-- Resplandor frutal sutil en esquina superior -->
  <div
    class="absolute top-0 right-0 w-[480px] h-[360px] pointer-events-none"
    style="background: radial-gradient(ellipse at 80% 0%, color-mix(in srgb, var(--color-cherry) 12%, transparent), transparent 70%)"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-0 left-0 w-[400px] h-[300px] pointer-events-none"
    style="background: radial-gradient(ellipse at 20% 100%, color-mix(in srgb, var(--color-grape) 10%, transparent), transparent 70%)"
    aria-hidden="true"
  ></div>

  <!-- Franja frutal en la parte superior -->
  <div class="absolute top-0 left-0 right-0">
    <div class="fruit-strip"></div>
  </div>

  <div class="relative max-w-[820px] mx-auto text-center reveal">
    <p class="font-mono text-[11px] tracking-[0.16em] uppercase text-sun/80 mb-5">Apúntate</p>

    <h2 class="font-sazon text-[clamp(34px,5vw,60px)] leading-[1.05] [letter-spacing:var(--tracking-tightest)] font-medium mb-6">
      Queremos construir este servicio<br />junto a vosotros.
    </h2>

    <p class="text-[17px] md:text-[18px] leading-[1.55] text-cream/75 mb-10 max-w-[520px] mx-auto">
      Si te interesa recibir fruta realmente buena en casa, déjanos tu contacto. Nada más.
    </p>

    <LeadForm idSuffix="-cta" cta="Quiero ser de los primeros" variant="inverse" />
  </div>

  <!-- Label campo -->
  <div class="absolute bottom-6 right-5 md:right-10 flex items-center gap-2.5" aria-hidden="true">
    <div class="w-8 opacity-30" style="height:1px; background: var(--color-cream)"></div>
    <span class="campo-label text-cream">La bodega</span>
  </div>
</section>
