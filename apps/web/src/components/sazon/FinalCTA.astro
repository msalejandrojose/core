---
import LeadForm from './LeadForm.astro';
---
<section id="contacto" class="px-5 md:px-10 py-24 md:py-36 bg-forest text-cream">
  <div class="max-w-[820px] mx-auto text-center reveal">
    <p class="font-mono text-[11px] tracking-[0.16em] uppercase text-sun/80 mb-5">Apúntate</p>
    <h2 class="font-sazon text-[clamp(34px,5vw,60px)] leading-[1.05] [letter-spacing:var(--tracking-tightest)] font-medium mb-6">
      Queremos construir este servicio<br />junto a vosotros.
    </h2>
    <p class="text-[17px] md:text-[18px] leading-[1.55] text-cream/75 mb-10 max-w-[520px] mx-auto">
      Si te interesa recibir fruta realmente buena en casa, déjanos tu contacto. Nada más.
    </p>

    <LeadForm idSuffix="-cta" cta="Quiero ser de los primeros" variant="inverse" />
  </div>
</section>
