---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import ContactForm from '../components/islands/ContactForm';
---

<MarketingLayout
  title="Contacto"
  description="Ponte en contacto con nosotros. Cuéntanos en qué podemos ayudarte."
>
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <!-- Intro -->
        <div class="lg:sticky lg:top-32">
          <h1 class="font-display text-4xl lg:text-5xl font-semibold tracking-tight text-fg">
            Hablemos
          </h1>
          <p class="mt-5 text-lg leading-relaxed text-fg-muted">
            Cuéntanos en qué podemos ayudarte y nos pondremos en contacto contigo lo antes posible.
          </p>
          <div class="mt-10 space-y-4">
            <div class="flex items-center gap-3 text-fg-muted text-sm">
              <span class="text-brand" aria-hidden="true">✦</span>
              Respuesta en menos de 24 horas
            </div>
            <div class="flex items-center gap-3 text-fg-muted text-sm">
              <span class="text-brand" aria-hidden="true">✦</span>
              Sin compromisos ni letra pequeña
            </div>
          </div>
        </div>

        <!-- Formulario (React island — client:load para smoke test de CORS) -->
        <div>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
