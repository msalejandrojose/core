---
import type { GetStaticPaths } from 'astro';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { getAllPublishedPosts } from '../../lib/blog';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getAllPublishedPosts();
  const sorted = [...posts].sort((a, b) => {
    const aDate = a.publishedAt ? new Date(a.publishedAt).getTime() : 0;
    const bDate = b.publishedAt ? new Date(b.publishedAt).getTime() : 0;
    return bDate - aDate;
  });
  return paginate(sorted, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<MarketingLayout
  title={page.currentPage === 1 ? 'Blog' : `Blog — página ${page.currentPage}`}
  description="Artículos, novedades y guías de Core."
>
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <header class="max-w-2xl mb-16">
        <h1 class="font-display text-4xl lg:text-5xl font-semibold tracking-tight text-fg">
          Blog
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-fg-muted">
          Artículos, novedades y guías.
        </p>
      </header>

      {page.data.length === 0 ? (
        <p class="text-fg-muted">Todavía no hay artículos publicados.</p>
      ) : (
        <ul class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3" role="list">
          {page.data.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="group block">
                {post.coverImageUrl && (
                  <div class="mb-4 aspect-[16/10] overflow-hidden rounded-lg bg-bg-muted">
                    <img
                      src={post.coverImageUrl}
                      alt=""
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                )}
                {post.category && (
                  <p class="text-xs font-medium tracking-wide uppercase text-brand mb-2">
                    {post.category.name}
                  </p>
                )}
                <h2 class="font-display text-xl font-semibold tracking-tight text-fg group-hover:text-brand transition-colors">
                  {post.title}
                </h2>
                {post.excerpt && (
                  <p class="mt-2 text-sm leading-relaxed text-fg-muted line-clamp-3">
                    {post.excerpt}
                  </p>
                )}
                {post.publishedAt && (
                  <p class="mt-3 text-xs text-fg-subtle">
                    {dateFormatter.format(new Date(post.publishedAt))}
                  </p>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}

      {(page.url.prev || page.url.next) && (
        <nav class="mt-16 flex items-center justify-between" aria-label="Paginación del blog">
          {page.url.prev ? (
            <a href={page.url.prev} class="text-sm text-fg-muted hover:text-fg transition-colors">
              ← Más recientes
            </a>
          ) : <span />}
          {page.url.next && (
            <a href={page.url.next} class="text-sm text-fg-muted hover:text-fg transition-colors">
              Más antiguos →
            </a>
          )}
        </nav>
      )}
    </div>
  </section>
</MarketingLayout>
