---
import type { GetStaticPaths } from 'astro';
import { marked } from 'marked';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { getAllPublishedPosts, getPublishedPost } from '../../lib/blog';

export const getStaticPaths = (async () => {
  const summaries = await getAllPublishedPosts();
  const posts = await Promise.all(summaries.map((s) => getPublishedPost(s.slug)));
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;

// El contenido lo escriben editores autenticados del backoffice (no público),
// así que se renderiza el Markdown a HTML sin sanitizar aparte.
const html = marked.parse(post.content, { async: false }) as string;

const dateFormatter = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const authorName = post.author
  ? [post.author.firstName, post.author.lastName].filter(Boolean).join(' ') || null
  : null;
---

<MarketingLayout
  title={post.metaTitle ?? post.title}
  description={post.metaDescription ?? post.excerpt ?? undefined}
  image={post.coverImageUrl ?? undefined}
  type="article"
>
  <article class="py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <a href="/blog" class="text-sm text-fg-muted hover:text-fg transition-colors">← Blog</a>

      <header class="mt-6 mb-10">
        {post.category && (
          <a
            href={`/blog?categoria=${post.category.slug}`}
            class="text-xs font-medium tracking-wide uppercase text-brand"
          >
            {post.category.name}
          </a>
        )}
        <h1 class="mt-3 font-display text-4xl lg:text-5xl font-semibold tracking-tight text-fg leading-[1.1]">
          {post.title}
        </h1>
        <div class="mt-5 flex items-center gap-3 text-sm text-fg-subtle">
          {authorName && <span>{authorName}</span>}
          {authorName && post.publishedAt && <span aria-hidden="true">·</span>}
          {post.publishedAt && (
            <time datetime={post.publishedAt}>{dateFormatter.format(new Date(post.publishedAt))}</time>
          )}
        </div>
      </header>

      {post.coverImageUrl && (
        <div class="mb-10 aspect-[16/9] overflow-hidden rounded-lg bg-bg-muted">
          <img src={post.coverImageUrl} alt="" class="h-full w-full object-cover" />
        </div>
      )}

      <div class="prose-post" set:html={html} />

      {post.tags.length > 0 && (
        <ul class="mt-12 flex flex-wrap gap-2" role="list" aria-label="Etiquetas">
          {post.tags.map((tag) => (
            <li class="rounded-full border border-border px-3 py-1 text-xs text-fg-muted">
              {tag.name}
            </li>
          ))}
        </ul>
      )}
    </div>
  </article>
</MarketingLayout>

<style>
  .prose-post {
    color: var(--color-fg);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-post :global(h2) {
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .prose-post :global(h3) {
    margin-top: 2em;
    margin-bottom: 0.6em;
    font-size: 1.25rem;
    font-weight: 600;
  }
  .prose-post :global(p) {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }
  .prose-post :global(a) {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-post :global(ul),
  .prose-post :global(ol) {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }
  .prose-post :global(ul) {
    list-style: disc;
  }
  .prose-post :global(ol) {
    list-style: decimal;
  }
  .prose-post :global(li + li) {
    margin-top: 0.4em;
  }
  .prose-post :global(blockquote) {
    margin: 1.75em 0;
    padding-left: 1.25em;
    border-left: 3px solid var(--color-border-strong);
    color: var(--color-fg-muted);
    font-style: italic;
  }
  .prose-post :global(img) {
    margin: 2em 0;
    border-radius: var(--radius-md);
  }
  .prose-post :global(code) {
    background: var(--color-bg-muted);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.4em;
    font-size: 0.875em;
  }
  .prose-post :global(pre) {
    margin: 1.75em 0;
    padding: 1em 1.25em;
    border-radius: var(--radius-md);
    background: var(--color-bg-muted);
    overflow-x: auto;
  }
  .prose-post :global(pre code) {
    background: none;
    padding: 0;
  }
</style>
