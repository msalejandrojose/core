---
import '../styles/huerto.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title       = 'Fruta Directa del Huerto | Más sabor, mejor calidad y mejor precio',
  description = 'Descubre una nueva forma de comprar fruta fresca directamente del agricultor. Más sabor, mayor calidad y sin intermediarios. Apúntate para conocer el lanzamiento.',
  canonical   = Astro.url.href,
} = Astro.props;

const siteName = 'Huerto';
const ogImage  = new URL('/og.jpg', Astro.site ?? Astro.url).href;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#FAFAF7" />
  <meta name="robots" content="index,follow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:type"        content="website" />
  <meta property="og:locale"      content="es_ES" />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:image"       content={ogImage} />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "Huerto Directo",
        "url": Astro.site?.href ?? Astro.url.origin,
        "description": "Fruta fresca directamente del agricultor al consumidor, con menos intermediarios y más sabor."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Ya puedo comprar?",
            "acceptedAnswer": { "@type": "Answer", "text": "Todavía no. Estamos preparando el lanzamiento del servicio." }
          },
          {
            "@type": "Question",
            "name": "¿Dónde realizaréis envíos?",
            "acceptedAnswer": { "@type": "Answer", "text": "Inicialmente dentro de España." }
          },
          {
            "@type": "Question",
            "name": "¿Cómo sabré cuándo estará disponible?",
            "acceptedAnswer": { "@type": "Answer", "text": "Recibirás un correo en cuanto abramos el servicio." }
          },
          {
            "@type": "Question",
            "name": "¿Habrá fruta todo el año?",
            "acceptedAnswer": { "@type": "Answer", "text": "Trabajaremos principalmente con fruta de temporada, seleccionada en su mejor momento." }
          }
        ]
      }
    ]
  })} />
</head>
<body>
  <slot />

  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        }
      }, { threshold: 0.08, rootMargin: '0px 0px -5% 0px' });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    }

    const sentinel = document.getElementById('scroll-sentinel');
    const header   = document.getElementById('site-header');
    if (sentinel && header) {
      new IntersectionObserver(([entry]) => {
        header.classList.toggle('scrolled', !entry.isIntersecting);
      }).observe(sentinel);
    }
  </script>
</body>
</html>
