---
import '../styles/sazon.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Sazón — Fruta de temporada a domicilio en Albacete',
  description = 'Seleccionamos personalmente la mejor fruta de temporada y la llevamos a tu casa en Albacete. Estamos validando el interés. Apúntate para ser de los primeros.',
  canonical = Astro.url.href,
} = Astro.props;

const siteName = 'Sazón';
const ogImage = new URL('/og.jpg', Astro.site ?? Astro.url).href;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#FAF6EC" />
  <meta name="robots" content="index,follow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,400;1,9..144,500;1,9..144,600&family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": siteName,
        "url": Astro.site?.href ?? Astro.url.origin,
        "areaServed": "Albacete, España"
      },
      {
        "@type": "LocalBusiness",
        "name": siteName,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Albacete",
          "addressRegion": "Castilla-La Mancha",
          "addressCountry": "ES"
        },
        "description": "Servicio de fruta de temporada seleccionada personalmente y entregada a domicilio en Albacete."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "¿Por qué me pedís el contacto?", "acceptedAnswer": { "@type": "Answer", "text": "Porque queremos saber si esta idea interesa en Albacete antes de lanzarla." } },
          { "@type": "Question", "name": "¿Cuándo estará disponible?", "acceptedAnswer": { "@type": "Answer", "text": "Estamos validando el interés. Avisaremos a quienes se apunten en cuanto abramos." } },
          { "@type": "Question", "name": "¿Tiene algún compromiso?", "acceptedAnswer": { "@type": "Answer", "text": "No. Simplemente recibirás información cuando abramos." } },
          { "@type": "Question", "name": "¿En qué zonas trabajaréis?", "acceptedAnswer": { "@type": "Answer", "text": "Comenzaremos por Albacete capital." } }
        ]
      }
    ]
  })} />
</head>
<body>
  <slot />

  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Reveal al entrar en viewport
    if (reduceMotion) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        }
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    }

    // Tilt 3D siguiendo al puntero — sólo en punteros finos y sin reduced-motion.
    // No usa scroll: escucha pointermove sobre cada superficie y actualiza
    // variables CSS dentro de un rAF. El parallax de scroll vive en CSS.
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    if (finePointer && !reduceMotion) {
      for (const el of document.querySelectorAll<HTMLElement>('[data-tilt]')) {
        const max = parseFloat(el.getAttribute('data-tilt-max') || '6');
        let raf = 0, rx = 0, ry = 0, mx = 50, my = 50;
        const apply = () => {
          el.style.setProperty('--rx', rx.toFixed(2) + 'deg');
          el.style.setProperty('--ry', ry.toFixed(2) + 'deg');
          el.style.setProperty('--mx', mx.toFixed(1) + '%');
          el.style.setProperty('--my', my.toFixed(1) + '%');
          raf = 0;
        };
        el.addEventListener('pointermove', (e: PointerEvent) => {
          const r = el.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width;
          const py = (e.clientY - r.top) / r.height;
          ry = (px - 0.5) * max * 2;
          rx = -(py - 0.5) * max * 2;
          mx = px * 100; my = py * 100;
          el.classList.add('tilting');
          if (!raf) raf = requestAnimationFrame(apply);
        });
        el.addEventListener('pointerleave', () => {
          rx = 0; ry = 0;
          el.classList.remove('tilting');
          if (!raf) raf = requestAnimationFrame(apply);
        });
      }
    }
  </script>
</body>
</html>
