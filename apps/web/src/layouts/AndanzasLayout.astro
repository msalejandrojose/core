---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/andanzas/SiteHeader.astro';
import SiteFooter from '../components/andanzas/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} siteName="Andanzas">
  <div class="flex flex-col min-h-dvh">
    <SiteHeader />
    <main class="flex-1">
      <slot />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
