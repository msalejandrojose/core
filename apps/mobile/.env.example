# URL de la API de Core. En local con el stack: http://api.aj-local.es
# (o http://localhost:3000 si arrancas la API a pelo). Solo las variables con
# prefijo VITE_ se exponen al bundle.
VITE_API_URL=http://localhost:3000

# Login social — Google (Google Cloud Console → APIs & Services → Credentials).
# No son secretos (van en el bundle del cliente), solo identifican la app.
# `WEB_CLIENT_ID` se usa en Android (Credential Manager) y es el mismo que
# debe configurarse en la API como `GOOGLE_CLIENT_ID`.
VITE_GOOGLE_WEB_CLIENT_ID=
VITE_GOOGLE_IOS_CLIENT_ID=

# Login social — Facebook (developers.facebook.com → tu app → Configuración básica).
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_CLIENT_TOKEN=
