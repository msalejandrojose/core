{
  "name": "core",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo: NestJS API + Backoffice (React) + Web (Astro) + Mobile (Ionic)",
  "scripts": {
    "dev:api": "pnpm --filter @core/api start:dev",
    "build:api": "pnpm --filter @core/api... build",
    "dev:backoffice": "pnpm --filter @core/backoffice dev",
    "build:backoffice": "pnpm --filter @core/backoffice build",
    "preview:backoffice": "pnpm --filter @core/backoffice preview",
    "dev:web": "pnpm --filter @core/web dev",
    "build:web": "pnpm --filter @core/web build",
    "preview:web": "pnpm --filter @core/web preview",
    "dev:mobile": "pnpm --filter @core/mobile dev",
    "build:mobile": "pnpm --filter @core/mobile build",
    "preview:mobile": "pnpm --filter @core/mobile preview"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines"
    ]
  }
}
