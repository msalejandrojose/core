# Dependencies
node_modules/
.pnpm-store/

# Builds
dist/
build/
out/
.next/
.astro/
.turbo/
.cache/

# Prisma — cliente generado (regenerado en cada build, no se commitea)
apps/api/src/generated/

# api-client — schema generado desde OpenAPI (regenerar con: API_URL=http://localhost:3000 pnpm --filter @core/api-client generate)
packages/api-client/src/generated/schema.d.ts

# OpenAPI spec generado offline (artefacto de build/CI para tipar el api-client)
/openapi.json

# Storage module — ficheros subidos en local (driver LOCAL), nunca se commitean
apps/api/.storage/

# Caddyfile generado por run.sh desde stack.config.json (artefacto, no se commitea)
docker/Caddyfile

# Env
# Convención del backend (apps/api):
#   .env        → secretos locales, NUNCA committed
#   .env.local  → defaults NO-secretos compartidos por el equipo, SÍ committed
#   .env.example → plantilla committed
.env
.env.local
.env.*.local
!apps/api/.env.local
# Backoffice (Vite): .env lleva solo NO-secretos y SÍ se commitea; .env.local (secretos) queda ignorado.
!apps/backoffice/.env
# Web (Astro): .env.local lleva solo config de despliegue NO-secreta y compartida
# (ej. CLOUDFLARE_PROJECT_NAME), nunca PUBLIC_*, para no pisar overrides locales
# en .env (Vite carga .env.local DESPUÉS de .env y sobrescribe claves repetidas).
!apps/web/.env.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Test/coverage
coverage/
.nyc_output/

# Mobile (Ionic / Capacitor)
ios/build/
android/build/
android/.gradle/
android/app/build/
