# Credenciales del MySQL local. Copia este archivo a `docker/.env` antes de arrancar.

# Usuario root (admin). MYSQL_ROOT_USER es siempre "root" por convención de
# MySQL — la imagen oficial no lee la var, lo dejamos por claridad.
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=root

# Usuario de aplicación que crea la imagen para la base del proyecto.
MYSQL_DATABASE=core
MYSQL_USER=core
MYSQL_PASSWORD=core

MYSQL_PORT=3306

# Puerto en el que se publica la API cuando se levanta con `./run.sh full`
API_PORT=3000
